    {
        "id": "affa524e5f408a30",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "Armar URL Nube de Palabras (Tab 6)",
        "func": "// Limpiar espacios o saltos de línea de la respuesta de Linux\nvar ip = msg.payload.trim();\n\n// Si por alguna razón no hay IP, usar localhost por defecto para evitar errores\nif (ip === \"\") {\n    ip = \"127.0.0.1\";\n}\n\n// Construir la URL completa para el Tab 7 (Encuesta)\nmsg.payload = \"http://\" + ip + \":1880/ui/#!/6\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
