            []
        ]
    },
    {
        "id": "func_armar_url_qr",
        "type": "function",
        "z": "dc7152bb2106ef80",
        "name": "Armar URL Encuesta (Tab 7)",
        "func": "// Limpiar espacios o saltos de línea de la respuesta de Linux\nvar ip = msg.payload.trim();\n\n// Si por alguna razón no hay IP, usar localhost por defecto para evitar errores\nif (ip === \"\") {\n    ip = \"127.0.0.1\";\n}\n\n// Construir la URL completa para el Tab 7 (Encuesta)\nmsg.payload = \"http://\" + ip + \":1880/ui/#!/7\";\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 570,
        "y": 180,
        "wires": [
            [
                "1b5f63d9.5f042c"
            ]
        ]
    }
