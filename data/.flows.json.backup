    {
        "id": "9528ad360e332653",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "group_home",
        "name": "UI HOME",
        "order": 1,
        "width": "20",
        "height": "16",
        "format": "<!DOCTYPE html>\n<link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Rajdhani:wght@500;700&family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n<style>\n    .home-container {\n        display: flex;\n        flex-direction: column;\n        align-items: center;\n        justify-content: center;\n        height: 100%;\n        text-align: center;\n        color: #2c3e50; /* Texto oscuro para legibilidad */\n        background-color: transparent; /* Fondo transparente para integrar con el tema Light */\n        padding: 20px;\n    }\n\n    .home-title {\n        font-family: 'Rajdhani', sans-serif;\n        font-size: 4.5rem;\n        color: #2980b9; /* Azul fuerte y formal */\n        margin-bottom: 10px;\n        font-weight: 700;\n        text-shadow: 1px 1px 2px rgba(0,0,0,0.1);\n    }\n\n    .home-subtitle {\n        font-size: 1.8rem;\n        color: #34495e;\n        font-family: 'Roboto', sans-serif;\n        font-weight: 400;\n    }\n\n    .start-btn {\n        margin-top: 40px;\n        background: #27ae60; /* Verde amigable que invita a hacer clic */\n        color: white;\n        padding: 20px 50px;\n        border-radius: 30px;\n        text-decoration: none;\n        font-weight: bold;\n        transition: all 0.3s ease;\n        border: none;\n        cursor: pointer;\n        font-size: 1.2rem;\n        display: inline-flex;\n        align-items: center;\n        gap: 10px;\n        box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n    }\n\n    .start-btn:hover {\n        background: #2ecc71;\n        transform: translateY(-3px);\n        box-shadow: 0 8px 15px rgba(46, 204, 113, 0.4);\n    }\n\n    .description {\n        margin-top: 60px;\n        max-width: 650px;\n        font-size: 1rem;\n        color: #555;\n        line-height: 1.8;\n        background: rgba(255,255,255,0.7);\n        padding: 20px;\n        border-radius: 10px;\n        border: 1px solid #eee;\n    }\n\n    /* Responsive Text */\n    @media (max-width: 768px) {\n        .home-title { font-size: 3rem; }\n        .home-subtitle { font-size: 1.3rem; }\n        .start-btn { padding: 15px 30px; font-size: 1rem; }\n    }\n</style>\n\n<div class=\"home-container\">\n    <h1 class=\"home-title\">PROYECTO TI</h1>\n    \n    <h2 class=\"home-subtitle\">Plataforma de Demostración de Procesamiento de Datos</h2>\n    \n    <div style=\"margin-top: 20px;\">\n        <button class=\"start-btn\" onclick=\"window.location.hash='#!/1'\">\n            <i class=\"fas fa-play\"></i> INICIAR DEMO\n        </button>\n    </div>\n    \n    <div class=\"description\">\n        Este componente permite la recolección, transformación y análisis de datos en tiempo real \n        utilizando sensores IoT y algoritmos de inteligencia artificial.\n    </div>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
        "className": "",
        "x": 140,
        "y": 60,
        "wires": [
            []
        ]
    },
    {
        "id": "ab3c76337d3ebc27",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "CEREBRO ETL (Python -> JS)",
        "func": "// --- 1. GESTIÓN DE ESTADO (MEMORIA PERSISTENTE) ---\nvar filters = context.get('filters') || { \n    remove_zeros: false, \n    smoothing: false, \n    normalization: false, \n    sim_active: true\n};\nvar buffer = context.get('buffer') || [];\nvar t = context.get('t') || 0;\n\n// --- 2. ENTRADAS DE CONTROL (UI) ---\nif (msg.topic === \"update_filters\") {\n    if (msg.payload.sim_active !== undefined) {\n        filters.sim_active = msg.payload.sim_active;\n    }\n    filters.remove_zeros = msg.payload.remove_zeros;\n    filters.smoothing = msg.payload.smoothing;\n    filters.normalization = msg.payload.normalization;\n    \n    context.set('filters', filters);\n    \n    return { \n        payload: { \n            raw: 0, clean: 0, category: null, \n            config: filters \n        } \n    };\n}\n\n// --- 3. OBTENCIÓN DE DATOS ---\nvar base_val = 0;\nvar data_valid = false;\n\nif (filters.sim_active) {\n    if (msg.payload.sound_bruto !== undefined) return null;\n\n    t += 1; \n    context.set('t', t);\n    \n    // Simulación ajustada a la nueva escala (0 a 4000)\n    if (Math.random() > 0.8) {\n        // Pico de ruido (palmada)\n        base_val = Math.floor(Math.random() * 2000) + 2000;\n    } else if (Math.random() > 0.5) {\n         // Murmullo\n         base_val = Math.floor(Math.random() * 800) + 200;\n    } else {\n         // Silencio\n         base_val = 0;\n    }\n    \n    data_valid = true;\n} else {\n    if (msg.payload.sound_bruto === undefined) return null;\n    \n    base_val = msg.payload.sound_bruto || 0;\n    data_valid = true;\n}\n\nif (!data_valid) return null;\n\n// --- 4. PROCESAMIENTO ETL ---\nvar processed_val = base_val;\n\n// A. Filtro: Eliminar Ceros (Para KY-038 esto es útil para ver el ruido de fondo)\nif (filters.remove_zeros) {\n    if (base_val < 50) {\n        var sum = buffer.reduce((a, b) => a + b, 0);\n        processed_val = buffer.length > 0 ? (sum / buffer.length) : 0;\n    }\n}\n\nbuffer.push(processed_val);\nif (buffer.length > 10) buffer.shift();\ncontext.set('buffer', buffer);\n\n// B. Filtro: Suavizado (Media Movil)\nif (filters.smoothing) {\n    if (buffer.length > 0) {\n        var sum = buffer.reduce((a, b) => a + b, 0);\n        processed_val = sum / buffer.length;\n    }\n}\n\n// C. Filtro: Normalización\nif (filters.normalization) {\n    processed_val = (processed_val / 4095.0) * 100.0;\n}\n\n// --- 5. CATEGORIZACIÓN (Franja ancha para conversación) ---\nvar cat_text = \"SILENCIO\";\nvar cat_color = \"#2ecc71\"; // Verde\nvar cat_icon = \"fa-volume-mute\";\n\nif (filters.normalization) {\n    if (processed_val >= 2) { cat_text = \"MURMULLO\"; cat_color = \"#f1c40f\"; cat_icon = \"fa-volume-down\"; }\n    if (processed_val >= 15) { cat_text = \"CONVERSACIÓN\"; cat_color = \"#e67e22\"; cat_icon = \"fa-user-friends\"; }\n    if (processed_val >= 60) { cat_text = \"RUIDO FUERTE\"; cat_color = \"#e74c3c\"; cat_icon = \"fa-bullhorn\"; }\n} else {\n    // Escala Bruta (0 a 4095)\n    if (processed_val >= 100) { cat_text = \"MURMULLO\"; cat_color = \"#f1c40f\"; cat_icon = \"fa-volume-down\"; }\n    // Abrimos la franja de Conversación desde 600 hasta 2500\n    if (processed_val >= 600) { cat_text = \"CONVERSACIÓN\"; cat_color = \"#e67e22\"; cat_icon = \"fa-user-friends\"; }\n    if (processed_val >= 2500) { cat_text = \"RUIDO FUERTE\"; cat_color = \"#e74c3c\"; cat_icon = \"fa-bullhorn\"; }\n}\n\n// --- 6. SALIDA ---\nmsg.payload = {\n    raw: base_val,\n    clean: processed_val,\n    category: { \n        text: cat_text, \n        color: cat_color, \n        icon: cat_icon \n    },\n    config: filters\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 400,
        "wires": [
            [
                "95801775efe6280e"
            ]
        ]
    },
    {
        "id": "95801775efe6280e",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "group_esc2_main",
        "name": "UI SC2 - ETL PIPELINE",
        "order": 1,
        "width": "25",
        "height": "11",
        "format": "<!DOCTYPE html>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Rajdhani:wght@500;700&family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n<style>\n    :root { --primary-bg: #ecf0f1; --accent: #2980b9; --success: #27ae60; --danger: #c0392b; --warning: #f39c12; --text-dark: #2c3e50; }\n    .main-container { display: flex; height: 100%; font-family: 'Roboto', sans-serif; background-color: var(--primary-bg); color: var(--text-dark); overflow: hidden; width: 100%; position: absolute; top:0; left:0;}\n    .content-area { flex: 1; padding: 20px; overflow-y: auto; height: 100%; box-sizing: border-box; width: 100%; }\n\n    .etl-layout { display: flex; height: 100%; gap: 20px; padding: 10px; align-items: stretch; }\n    .chart-panel { flex: 2; background: white; border-radius: 15px; padding: 15px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; position: relative; overflow: hidden; min-height: 400px; }\n    .control-panel { flex: 1; background: white; border-radius: 15px; padding: 20px; color: var(--text-dark); display: flex; flex-direction: column; gap: 15px; align-items: center; box-shadow: 0 5px 15px rgba(0,0,0,0.05); min-width: 250px; max-width: 400px; border: 1px solid #e0e0e0;}\n    \n    .panel-header { font-family: 'Rajdhani'; font-size: 1.5rem; margin-bottom: 10px; display: flex; justify-content: space-between; align-items: center; font-weight: bold; width: 100%;}\n    .bad-text { color: var(--danger); }\n    .good-text { color: var(--success); }\n    \n    .filter-row { width: 100%; background: #f8f9fa; padding: 15px; border-radius: 10px; display: flex; justify-content: space-between; align-items: center; transition: 0.3s; cursor: pointer; border: 1px solid #eee;}\n    .filter-row:hover { background: #e9ecef; }\n    .filter-row.active-sim { background: rgba(243, 156, 18, 0.1); border-color: var(--warning); }\n    .filter-title { font-weight: bold; font-size: 0.9rem; color: #2c3e50; }\n    .filter-desc { font-size: 0.7rem; color: #7f8c8d; }\n    \n    .live-val { font-family: 'Orbitron'; font-size: 3.5rem; margin-top: auto; align-self: center; text-align: center; }\n    \n    .category-card { margin-top: 20px; width: 90%; padding: 15px; border-radius: 10px; text-align: center; color: white; transition: 0.3s; box-shadow: 0 5px 15px rgba(0,0,0,0.1); display: flex; flex-direction: column; align-items: center; }\n    .cat-icon { font-size: 3rem; margin-bottom: 5px; }\n    .cat-text { font-family: 'Rajdhani'; font-size: 2rem; font-weight: bold; letter-spacing: 2px; }\n    .cat-label { font-size: 0.8rem; opacity: 0.8; text-transform: uppercase; }\n    \n    .sim-overlay { position: absolute; top: 10px; right: 10px; background: var(--warning); color: white; padding: 5px 10px; border-radius: 5px; font-weight: bold; font-size: 0.7rem; z-index: 10;}\n</style>\n\n<div class=\"main-container\">\n    <div class=\"content-area\">\n        <div class=\"etl-layout\">\n            \n            <div class=\"chart-panel\" style=\"border-top: 5px solid var(--danger);\">\n                <div class=\"sim-overlay\" ng-show=\"filters.sim_active\">SIMULACIÓN</div>\n                <div class=\"panel-header bad-text\"><span><i class=\"fas fa-bug\"></i> RAW DATA</span></div>\n                <div style=\"flex: 1; position: relative; width:100%; height:100%;\"><canvas id=\"rawChart\"></canvas></div>\n                <div class=\"live-val bad-text\">{{rawVal | number:0}}</div>\n            </div>\n\n            <div class=\"control-panel\">\n                <div style=\"text-align: center; border-bottom: 2px solid #f0f0f0; padding-bottom: 15px; width: 100%;\">\n                    <i class=\"fas fa-cogs\" style=\"font-size: 2rem; color: var(--accent);\"></i>\n                    <h3 style=\"font-family:'Rajdhani'; margin:5px 0; color:var(--text-dark);\">ETL PIPELINE</h3>\n                </div>\n                <div class=\"filter-row\" ng-class=\"{'active-sim': filters.sim_active}\">\n                    <div><div class=\"filter-title\">SIMULACIÓN</div><div class=\"filter-desc\">Generar datos</div></div>\n                    <md-switch ng-model=\"filters.sim_active\" aria-label=\"Sim\" ng-change=\"updateFilters()\"></md-switch>\n                </div>\n                <div class=\"filter-row\">\n                    <div><div class=\"filter-title\">1. LIMPIEZA</div><div class=\"filter-desc\">Eliminar ceros</div></div>\n                    <md-switch ng-model=\"filters.remove_zeros\" aria-label=\"F1\" ng-change=\"updateFilters()\"></md-switch>\n                </div>\n                <div class=\"filter-row\">\n                    <div><div class=\"filter-title\">2. SUAVIZADO</div><div class=\"filter-desc\">Media Móvil</div></div>\n                    <md-switch ng-model=\"filters.smoothing\" aria-label=\"F2\" ng-change=\"updateFilters()\"></md-switch>\n                </div>\n                <div class=\"filter-row\">\n                    <div><div class=\"filter-title\">3. NORMALIZACIÓN</div><div class=\"filter-desc\">Escalar (0-100%)</div></div>\n                    <md-switch ng-model=\"filters.normalization\" aria-label=\"F3\" ng-change=\"updateFilters()\"></md-switch>\n                </div>\n            </div>\n\n            <div class=\"chart-panel\" style=\"border-top: 5px solid var(--success);\">\n                <div class=\"panel-header good-text\"><span><i class=\"fas fa-check-circle\"></i> DATOS LIMPIOS</span></div>\n                <div style=\"flex: 1; position: relative; width:100%; height:100%;\"><canvas id=\"cleanChart\"></canvas></div>\n                \n                <div class=\"live-val good-text\">\n                    {{cleanVal | number: filters.normalization ? 1 : 0}}{{filters.normalization ? '%' : ''}}\n                </div>\n\n                <div class=\"category-card\" ng-style=\"{'background-color': catData.color}\">\n                    <div class=\"cat-label\">INSIGHT</div>\n                    <i class=\"fas cat-icon\" ng-class=\"catData.icon\"></i>\n                    <div class=\"cat-text\">{{catData.text}}</div>\n                </div>\n            </div>\n\n        </div>\n    </div>\n</div>\n\n<script>\n(function(scope) {\n    scope.filters = { remove_zeros: false, smoothing: false, normalization: false, sim_active: true };\n    scope.rawVal = 0;\n    scope.cleanVal = 0;\n    scope.catData = { text: \"ESPERANDO...\", color: \"#95a5a6\", icon: \"fa-minus\" };\n    \n    var rawChart, cleanChart;\n    var maxPoints = 50;\n\n    scope.updateFilters = function() {\n        scope.send({ topic: \"update_filters\", payload: scope.filters });\n        if(cleanChart) {\n            cleanChart.options.scales.y.max = scope.filters.normalization ? 100 : 4200;\n            cleanChart.update('none'); \n        }\n    };\n\n    setTimeout(function() {\n        // RAW CHART\n        var ctxRaw = document.getElementById('rawChart');\n        if(ctxRaw) {\n            rawChart = new Chart(ctxRaw, {\n                type: 'line',\n                data: {\n                    labels: Array(maxPoints).fill(''),\n                    datasets: [{ data: Array(maxPoints).fill(0), borderColor: '#c0392b', borderWidth: 2, pointRadius: 0, tension: 0 }]\n                },\n                options: {\n                    responsive: true, maintainAspectRatio: false, \n                    animation: false, \n                    plugins: { legend: { display: false } },\n                    scales: { y: { min: 0, max: 4200 }, x: { display: false } }\n                }\n            });\n        }\n\n        // CLEAN CHART\n        var ctxClean = document.getElementById('cleanChart');\n        if(ctxClean) {\n            cleanChart = new Chart(ctxClean, {\n                type: 'line',\n                data: {\n                    labels: Array(maxPoints).fill(''),\n                    datasets: [{ \n                        data: Array(maxPoints).fill(0), \n                        borderColor: '#27ae60', borderWidth: 3, pointRadius: 0, tension: 0.4, fill: true, backgroundColor: 'rgba(39, 174, 96, 0.1)' \n                    }]\n                },\n                options: {\n                    responsive: true, maintainAspectRatio: false, \n                    animation: false, \n                    plugins: { legend: { display: false } },\n                    scales: { y: { min: 0, max: 4200 }, x: { display: false } }\n                }\n            });\n        }\n    }, 500);\n\n    scope.$watch('msg.payload', function(newVal) {\n        if (!newVal) return;\n        \n        scope.rawVal = newVal.raw || 0;\n        scope.cleanVal = newVal.clean || 0;\n        if (newVal.category) scope.catData = newVal.category;\n\n        if (rawChart) {\n            var rData = rawChart.data.datasets[0].data;\n            rData.push(scope.rawVal);\n            rData.shift();\n            rawChart.update('none');\n        }\n        if (cleanChart) {\n            var cData = cleanChart.data.datasets[0].data;\n            cData.push(scope.cleanVal);\n            cData.shift();\n            cleanChart.update('none');\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
