    {
        "id": "fd5c6e3fbb3f3b7b",
        "type": "inject",
        "z": "0b3362ab9d38a37d",
        "name": "Clock (250ms)",
        "props": [
            {
                "p": "payload"
            }
        ],
        "repeat": "0.5",
        "crontab": "",
        "once": false,
        "onceDelay": 0.1,
        "topic": "",
        "payload": "",
