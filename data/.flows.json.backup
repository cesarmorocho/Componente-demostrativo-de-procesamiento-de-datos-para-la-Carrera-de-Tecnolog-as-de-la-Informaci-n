    {
        "id": "exec_obtener_ip",
        "type": "exec",
        "z": "dc7152bb2106ef80",
        "command": "hostname -I | awk '{print $1}'",
        "addpay": false,
        "append": "",
        "useSpawn": "false",
        "timer": "",
        "winHide": false,
        "oldrc": false,
        "name": "Leer IP LAN",
