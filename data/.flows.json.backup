    {
        "id": "5a2d4607792c2722",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "group_esc4_main",
        "name": "UI SC4 - AULA INTELIGENTE",
        "order": 1,
        "width": "20",
        "height": "16",
        "format": "<!DOCTYPE html>\n<link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Rajdhani:wght@500;700&family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n<style>\n    :root { --primary-bg: #ecf0f1; --accent: #2980b9; --success: #27ae60; --danger: #c0392b; --warning: #f39c12; --text-dark: #2c3e50; }\n    .main-container { display: flex; height: 100%; font-family: 'Roboto', sans-serif; background-color: var(--primary-bg); color: var(--text-dark); overflow: hidden; width: 100%; position: absolute; top:0; left:0; }\n    .content-area { flex: 1; padding: 20px; overflow-y: auto; height: 100%; box-sizing: border-box; width: 100%; }\n\n    /* --- LAYOUT RESPONSIVE --- */\n    .sc4-layout { \n        display: flex; \n        flex-wrap: wrap; \n        gap: 20px; \n        padding: 10px; \n        align-items: stretch; \n        min-height: 100%;\n    }\n    \n    /* PANEL IZQUIERDO: ACTUADORES */\n    .actuators-panel { \n        flex: 1 1 350px;\n        background: white; \n        border-radius: 15px; \n        padding: 30px; \n        display: flex; \n        flex-direction: column; \n        gap: 20px; \n        justify-content: center; \n        position: relative; \n        min-height: 400px; \n        box-sizing: border-box; \n        border: 1px solid #e0e0e0;\n    }\n    \n    .actuator-card { background: #fdfdfd; border-radius: 15px; padding: 20px; display: flex; flex-direction: row; align-items: center; justify-content: space-between; transition: all 0.3s; height: 130px; border: 2px solid #eee; }\n    .icon-box { width: 90px; text-align: center; }\n    .actuator-icon { font-size: 3.5rem; color: #bdc3c7; transition: color 0.3s; }\n    .actuator-info { flex: 1; margin-left: 20px; }\n    .actuator-label { font-weight: bold; font-size: 1.3rem; color: var(--text-dark); font-family: 'Rajdhani'; }\n    .status-text { font-size: 1.1rem; margin-top: 5px; font-family: 'Orbitron'; color: #95a5a6; font-weight: bold; }\n\n    /* Estados Activos */\n    .actuator-card.active-light { background: rgba(243, 156, 18, 0.05); border-color: var(--warning); box-shadow: 0 4px 15px rgba(243, 156, 18, 0.15); }\n    .active-light .actuator-icon { color: var(--warning); text-shadow: 0 0 15px rgba(243, 156, 18, 0.5); }\n    .active-light .status-text { color: var(--warning); }\n    \n    .actuator-card.active-cool { background: rgba(41, 128, 185, 0.05); border-color: var(--accent); box-shadow: 0 4px 15px rgba(41, 128, 185, 0.15); }\n    .active-cool .actuator-icon { color: var(--accent); animation: spin 1.5s linear infinite; }\n    .active-cool .status-text { color: var(--accent); }\n\n    /* PANEL DERECHO: CONTROLES */\n    .controls-panel { \n        flex: 1 1 350px;\n        display: flex; \n        flex-direction: column; \n        gap: 20px; \n    }\n    .control-card { background: white; color: var(--text-dark); border-radius: 15px; padding: 25px; box-shadow: 0 4px 10px rgba(0,0,0,0.05); border: 1px solid #e0e0e0;}\n    .control-card-dark { background: #2c3e50; color: white; border-radius: 15px; padding: 25px; box-shadow: 0 4px 15px rgba(0,0,0,0.1); }\n    \n    input[type=range] { width: 100%; margin-top: 15px; cursor: pointer; accent-color: var(--accent); }\n    .val-display { font-size: 1.8rem; font-weight: bold; color: var(--accent); float: right; font-family: 'Orbitron'; margin-top: -5px;}\n    \n    /* Animaciones */\n    @keyframes spin { 100% { transform: rotate(360deg); } }\n    .timer-bar { width: 100%; height: 8px; background: #eee; margin-top: 10px; border-radius: 5px; overflow: hidden; }\n    .timer-fill { height: 100%; background: var(--danger); width: 0%; transition: width 0.2s linear; }\n    \n    .sim-overlay { position: absolute; top: 15px; right: 15px; background: var(--warning); color: white; padding: 5px 15px; border-radius: 5px; font-weight: bold; font-size: 0.8rem; z-index: 10; }\n\n</style>\n\n<div class=\"main-container\">\n    <div class=\"content-area\">\n        <div class=\"sc4-layout\">\n            \n            <div class=\"actuators-panel\">\n                <div class=\"sim-overlay\" ng-show=\"config.sim\">SIMULACIÓN</div>\n                <div style=\"font-family: 'Rajdhani'; font-size: 1.8rem; color: var(--text-dark); border-bottom: 2px solid #eee; padding-bottom: 15px; margin-bottom: 10px; text-align: center; font-weight: bold;\">\n                    <i class=\"fas fa-home\" style=\"color:var(--accent);\"></i> AULA INTELIGENTE (DOMÓTICA)\n                </div>\n\n                <div class=\"actuator-card\" ng-class=\"{'active-light': actuators.light}\">\n                    <div class=\"icon-box\"><i class=\"fas fa-lightbulb actuator-icon\"></i></div>\n                    <div class=\"actuator-info\">\n                        <div class=\"actuator-label\">ILUMINACIÓN (AUTO)</div>\n                        <div class=\"status-text\">{{actuators.light ? 'ENCENDIDA' : 'APAGADA'}}</div>\n                        <div style=\"font-size: 0.75rem; color: #7f8c8d; margin-top: 12px; display: flex; justify-content: space-between; font-weight: bold;\">\n                            <span>Timer de Inactividad:</span>\n                            <span>{{timer_pct}}%</span>\n                        </div>\n                        <div class=\"timer-bar\"><div class=\"timer-fill\" style=\"width: {{timer_pct}}%\"></div></div>\n                    </div>\n                </div>\n\n                <div class=\"actuator-card\" ng-class=\"{'active-cool': actuators.ac}\">\n                    <div class=\"icon-box\"><i class=\"fas fa-fan actuator-icon\"></i></div>\n                    <div class=\"actuator-info\">\n                        <div class=\"actuator-label\">VENTILACIÓN (AFORO)</div>\n                        <div class=\"status-text\">{{actuators.ac ? 'SISTEMA ACTIVO' : 'SISTEMA OFF'}}</div>\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"controls-panel\">\n                \n                <div class=\"control-card\">\n                    <div style=\"margin-bottom: 10px; font-size: 1.1rem; font-weight: bold;\">\n                        <i class=\"fas fa-sun\" style=\"color: var(--warning);\"></i> LUZ NATURAL (SOL) \n                        <span class=\"val-display\">{{inputs.light}}%</span>\n                    </div>\n                    <input type=\"range\" min=\"0\" max=\"100\" ng-model=\"inputs.light\" ng-change=\"manualOverride()\" \n                           ng-mousedown=\"startInteract()\" ng-mouseup=\"endInteract()\" ng-touchstart=\"startInteract()\" ng-touchend=\"endInteract()\">\n                    <div style=\"font-size: 0.8rem; color: #7f8c8d; margin-top: 10px;\">\n                        <i class=\"fas fa-info-circle\"></i> Si > 30%, se apaga la luz artificial.\n                    </div>\n                </div>\n\n                <div class=\"control-card\">\n                    <div style=\"margin-bottom: 10px; font-size: 1.1rem; font-weight: bold;\">\n                        <i class=\"fas fa-volume-up\" style=\"color: #8e44ad;\"></i> NIVEL DE RUIDO \n                        <span class=\"val-display\">{{inputs.sound}}%</span>\n                    </div>\n                    \n                    <input type=\"range\" min=\"0\" max=\"100\" ng-model=\"inputs.sound\" ng-change=\"manualOverride()\" \n                           ng-mousedown=\"startInteract()\" ng-mouseup=\"endInteract()\" ng-touchstart=\"startInteract()\" ng-touchend=\"endInteract()\">\n                    <div style=\"font-size: 0.8rem; color: #7f8c8d; margin-top: 10px;\">\n                        <i class=\"fas fa-info-circle\"></i> Si > 30%, se activa Ventilación.\n                    </div>\n                </div>\n\n                <div class=\"control-card-dark\">\n                    <div style=\"display:flex; justify-content:space-between; align-items:center; margin-bottom: 20px;\">\n                        <span style=\"font-weight:bold; font-size: 1.1rem;\"><i class=\"fas fa-walking\"></i> SENSOR PIR</span>\n                        <div style=\"display:flex; align-items:center; gap:5px; font-size:0.8rem; color:#bdc3c7;\">\n                            <span>Simulación:</span>\n                            <md-switch ng-model=\"config.sim\" aria-label=\"Sim\" ng-change=\"toggleSim()\" style=\"margin:0\"></md-switch>\n                        </div>\n                    </div>\n                    \n                    <div style=\"display: flex; justify-content: center; gap: 15px;\">\n                        <button ng-click=\"setPresence(true)\" style=\"flex: 1; padding: 15px 0; background: var(--success); border: none; border-radius: 8px; color: white; cursor: pointer; font-weight: bold; transition: 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.2);\"\n                                ng-style=\"{'opacity': inputs.presence ? 1 : 0.4, 'transform': inputs.presence ? 'scale(1.05)' : 'scale(1)'}\">\n                            DETECTADO\n                        </button>\n                        <button ng-click=\"setPresence(false)\" style=\"flex: 1; padding: 15px 0; background: var(--danger); border: none; border-radius: 8px; color: white; cursor: pointer; font-weight: bold; transition: 0.2s; box-shadow: 0 4px 6px rgba(0,0,0,0.2);\"\n                                ng-style=\"{'opacity': !inputs.presence ? 1 : 0.4, 'transform': !inputs.presence ? 'scale(1.05)' : 'scale(1)'}\">\n                            VACÍO\n                        </button>\n                    </div>\n                    <div style=\"text-align: center; margin-top: 25px; font-weight: bold; font-size: 1.2rem;\"\n                         ng-style=\"{color: inputs.presence ? '#2ecc71' : '#e74c3c'}\">\n                        {{inputs.presence ? 'MOVIMIENTO DETECTADO' : 'SIN MOVIMIENTO (INACTIVO)'}}\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </div>\n</div>\n\n<script>\n(function(scope) {\n    // Se inicializa en 15% en lugar de los 500 crudos anteriores\n    scope.inputs = { light: 50, sound: 15, presence: true, timer: 0 };\n    scope.actuators = { light: false, ac: false };\n    scope.config = { sim: true };\n    scope.timer_pct = 0;\n    \n    scope.isUserInteracting = false;\n    scope.startInteract = function() { scope.isUserInteracting = true; };\n    scope.endInteract = function() { \n        scope.isUserInteracting = false; \n        scope.manualOverride(); \n    };\n\n    scope.manualOverride = function() {\n        scope.send({ topic: \"update_inputs\", payload: scope.inputs });\n    };\n    \n    scope.setPresence = function(state) {\n        scope.inputs.presence = state;\n        scope.manualOverride();\n    };\n\n    scope.toggleSim = function() {\n        scope.send({ topic: \"sim_switch\", payload: scope.config.sim });\n    };\n\n    scope.$watch('msg.payload', function(newVal) {\n        if (!newVal) return;\n\n        scope.actuators = newVal.actuators || { light: false, ac: false };\n        if(newVal.config) scope.config = newVal.config;\n        \n        var timer = newVal.inputs ? newVal.inputs.timer : 0;\n        scope.timer_pct = Math.min((timer / 30) * 100, 100).toFixed(0);\n\n        if (!scope.isUserInteracting && newVal.inputs) {\n            scope.inputs.light = newVal.inputs.light;\n            scope.inputs.sound = newVal.inputs.sound;\n            scope.inputs.presence = newVal.inputs.presence;\n        }\n    });\n})(scope);\n</script>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
