    {
        "id": "b2cdac37a3e7036a",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "group_esc1_v2",
        "name": "UI SC1 - TIEMPO REAL (RESPONSIVE)",
        "order": 1,
        "width": "20",
        "height": "16",
        "format": "<!DOCTYPE html>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Rajdhani:wght@500;700&family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n<style>\n    * { box-sizing: border-box; }\n    body, html { margin: 0; padding: 0; height: 100%; overflow: hidden; }\n    :root { --primary-bg: #1e272e; --accent: #00a8ff; --success: #00b894; --danger: #d63031; --warning: #fbc531; }\n    .main-container { display: flex; height: 100%; width: 100%; font-family: 'Roboto', sans-serif; background-color: #dcdde1; color: #2f3640; overflow: hidden; position: absolute; top:0; left:0; }\n    .sub-sidebar { width: 200px; flex-shrink: 0; background: linear-gradient(180deg, #2f3640 0%, #191f26 100%); display: flex; flex-direction: column; padding: 20px 10px; gap: 10px; box-shadow: 5px 0 15px rgba(0,0,0,0.1); overflow-y: auto; z-index: 10; }\n    .nav-btn { background: rgba(255,255,255,0.05); color: #bdc3c7; border: none; padding: 15px; text-align: left; font-family: 'Rajdhani', sans-serif; font-size: 1rem; font-weight: bold; border-radius: 10px; cursor: pointer; transition: 0.3s; display: flex; align-items: center; gap: 10px; }\n    .nav-btn:hover { background: rgba(255,255,255,0.1); color: white; transform: translateX(5px); }\n    .nav-btn.active { background: var(--accent); color: white; box-shadow: 0 5px 15px rgba(0, 168, 255, 0.3); }\n    .nav-btn.active-danger { background: #e74c3c !important; color: white !important; animation: pulseBtn 1s infinite; box-shadow: 0 0 15px #e74c3c; }\n    .content-area { flex: 1; padding: 20px; overflow-y: auto; overflow-x: hidden; height: 100%; position: relative; }\n    .audio-layout { display: flex; flex-direction: column; height: 100%; gap: 20px; }\n    .audio-top { display: flex; flex-direction: row; gap: 20px; width: 100%; flex-shrink: 0; }\n    .env-grid { display: grid; grid-template-columns: repeat(3, 1fr); gap: 20px; height: 100%; }\n    .env-col { display: flex; flex-direction: column; gap: 20px; height: 100%; min-height: 0; }\n    .cam-layout { display: flex; flex-direction: row; gap: 20px; height: 100%; }\n    .env-card { background: white; border-radius: 15px; padding: 20px; box-shadow: 0 5px 15px rgba(0,0,0,0.05); display: flex; flex-direction: column; align-items: center; justify-content: center; text-align: center; transition: 0.3s; height: 100%; flex: 1; min-height: 0; overflow: hidden; }\n    .env-title { font-family: 'Rajdhani', sans-serif; font-size: 1.1rem; color: #7f8c8d; text-transform: uppercase; margin-bottom: 10px; width: 100%; border-bottom: 1px solid #eee; padding-bottom: 5px; flex-shrink: 0; }\n    .big-icon { font-size: 3.5rem; margin-bottom: 10px; transition: 0.3s; }\n    .big-data { font-size: 2.5rem; font-weight: 700; color: #2f3640; }\n    .status-badge { padding: 8px 20px; border-radius: 30px; font-weight: bold; color: white; margin-top: 10px; font-size: 1.1rem; }\n    .sim-badge { position: absolute; top: 10px; right: 20px; background: var(--warning); color: #2f3640; padding: 5px 15px; border-radius: 20px; font-weight: bold; font-family: 'Rajdhani'; box-shadow: 0 0 10px var(--warning); display: none; z-index: 100; }\n    .vu-horizontal { width: 100%; height: 25px; background: #dfe6e9; border-radius: 15px; overflow: hidden; border: 1px solid #b2bec3; margin-top: 10px; }\n    .vu-bar { height: 100%; background: linear-gradient(to right, var(--success), var(--warning), var(--danger)); transition: width 0.05s ease-out; }\n    .siren { width: 60px; height: 60px; border-radius: 50%; background: #b2bec3; border: 4px solid #636e72; transition: 0.2s; }\n    .siren.alert { background: #ff4757; border-color: #d63031; box-shadow: 0 0 40px #ff4757; animation: blink 0.2s infinite alternate; }\n    .chart-wrapper { flex: 1; background: #2f3640; border-radius: 15px; padding: 10px; position: relative; border: 2px solid #353b48; overflow: hidden; min-height: 0; }\n    .radar-bar-bg { width: 80%; height: 15px; background: #eee; border-radius: 10px; margin-top: 15px; overflow: hidden; }\n    .radar-bar-fill { height: 100%; background: var(--accent); transition: 0.3s; }\n    .video-container { flex: 3; background: #000; border-radius: 15px; position: relative; overflow: hidden; display: flex; justify-content: center; align-items: center; border: 2px solid #333; min-height: 0; }\n    .cam-image { width: 100%; height: 100%; object-fit: contain; position: absolute; top: 0; left: 0; z-index: 1; }\n    .video-overlay-status { position: absolute; top: 20px; left: 20px; z-index: 10; font-family: 'Orbitron'; color: rgba(255,255,255,0.8); display: flex; gap: 10px; align-items: center; background: rgba(0,0,0,0.5); padding: 5px 10px; border-radius: 5px;}\n    .rec-dot { width: 12px; height: 12px; background: red; border-radius: 50%; animation: blink 1s infinite; }\n    .overlay-alert { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(214, 48, 49, 0.9); color: white; padding: 20px 40px; font-family: 'Rajdhani'; font-size: 2rem; font-weight: bold; border: 3px solid white; animation: pulseAlert 0.5s infinite; text-align: center; z-index: 20; display: none; }\n    .overlay-warning { position: absolute; bottom: 60px; left: 50%; transform: translateX(-50%); background: #f1c40f; color: black; padding: 10px 20px; font-weight: bold; border-radius: 5px; z-index: 15; display: none; }\n    .flash-effect { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: white; opacity: 0; pointer-events: none; z-index: 30; }\n    .flash-anim { animation: flash 0.3s ease-out; }\n    .privacy-curtain { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: #000; display: flex; flex-direction: column; align-items: center; justify-content: center; color: #555; z-index: 50; display: none; }\n    .ai-box { background: linear-gradient(135deg, #2c3e50 0%, #34495e 100%); color: white; border-radius: 15px; padding: 20px; text-align: center; border: 1px solid #444; flex-shrink: 0; }\n    .log-box { background: white; border-radius: 15px; padding: 15px; flex: 1; display: flex; flex-direction: column; overflow: hidden; min-height: 0; }\n    .log-list { flex: 1; overflow-y: auto; }\n    .log-item { padding: 8px; border-bottom: 1px solid #eee; display: flex; align-items: center; gap: 10px; font-size: 0.85rem; }\n    .log-item.crit { color: var(--danger); font-weight: bold; background: #fff5f5; }\n\n    .error-banner { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); background: rgba(214, 48, 49, 0.95); border: 2px solid white; border-radius: 15px; padding: 20px 40px; text-align: center; color: white; font-family: 'Rajdhani'; z-index: 100; box-shadow: 0 10px 30px rgba(0,0,0,0.5); display: none; }\n    .error-banner h3 { margin: 0; font-size: 1.5rem; font-weight: bold; }\n    .error-banner p { margin: 5px 0 0 0; font-size: 1rem; }\n\n    /* NUEVO CSS: Mini Banners para las tarjetas pequeñas */\n    .mini-error-banner { position: absolute; top: 0; left: 0; width: 100%; height: 100%; background: rgba(214, 48, 49, 0.95); display: flex; flex-direction: column; align-items: center; justify-content: center; color: white; border-radius: 15px; z-index: 20; display: none; text-align: center; font-family: 'Rajdhani'; }\n    .mini-error-banner i { font-size: 2.5rem; margin-bottom: 5px; }\n    .mini-error-banner span { font-weight: bold; font-size: 1.1rem; line-height: 1.1; }\n\n    @keyframes blink { from { opacity: 1; } to { opacity: 0.6; } }\n    @keyframes pulseAlert { 0% { transform: translate(-50%, -50%) scale(1); } 50% { transform: translate(-50%, -50%) scale(1.1); } 100% { transform: translate(-50%, -50%) scale(1); } }\n    @keyframes pulseBtn { 0% { transform: scale(1); } 50% { transform: scale(1.05); } 100% { transform: scale(1); } }\n    @keyframes flash { 0% { opacity: 1; } 100% { opacity: 0; } }\n</style>\n\n<div class=\"main-container\" ng-init=\"view='audio'\">\n    <div class=\"sub-sidebar\">\n        <div style=\"color: white; font-family: 'Rajdhani'; font-size: 1.2rem; padding: 10px; border-bottom: 1px solid #555; text-align:center;\">\n            <i class=\"fas fa-network-wired\" style=\"color:var(--accent)\"></i> ESCENARIO 1\n        </div>\n        <div style=\"padding: 10px; background: rgba(0,0,0,0.2); border-radius: 10px; margin-bottom: 10px;\">\n            <div style=\"display:flex; align-items:center; gap:10px; color:#bdc3c7; font-size:0.9rem; margin-bottom:5px;\">\n                <i class=\"fas fa-random\"></i> Simulación\n            </div>\n            <md-switch ng-model=\"config.sim\" aria-label=\"Sim\" ng-change=\"toggleSim()\" style=\"margin:0\"></md-switch>\n        </div>\n        <button class=\"nav-btn\" ng-class=\"{'active': view==='audio'}\" ng-click=\"view='audio'\">\n            <i class=\"fas fa-microphone-alt\"></i> Audio\n        </button>\n        <button class=\"nav-btn\" ng-class=\"{'active': view==='env'}\" ng-click=\"view='env'\">\n            <i class=\"fas fa-leaf\"></i> Ambiente\n        </button>\n        <button class=\"nav-btn\" ng-class=\"{'active': view==='sec'}\" ng-click=\"view='sec'\">\n            <i class=\"fas fa-shield-alt\"></i> Seguridad\n        </button>\n    </div>\n    <div class=\"content-area\">\n        <div id=\"simBadge\" class=\"sim-badge\"><i class=\"fas fa-gamepad\"></i> SIMULACIÓN</div>\n        \n        <div ng-show=\"view==='audio'\" class=\"audio-layout\">\n            <div class=\"audio-top\">\n                <div class=\"env-card\" style=\"flex: 1; align-items: stretch;\">\n                    <h3 class=\"env-title\">Intensidad de Entrada</h3>\n                    <div class=\"vu-horizontal\"><div id=\"vuBar\" class=\"vu-bar\" style=\"width: 0%\"></div></div>\n                    <div style=\"display: flex; justify-content: space-between; margin-top: 5px; font-size: 0.8rem; color: #888;\">\n                        <span>-40dB</span><span>0dB</span><span>+10dB</span>\n                    </div>\n                </div>\n                <div class=\"env-card\" style=\"width: 150px; flex: none;\">\n                    <h3 class=\"env-title\">Umbral</h3>\n                    <div id=\"siren\" class=\"siren\"></div>\n                    <span style=\"margin-top: 5px; font-size: 0.8rem; font-weight: bold;\">LIMITER</span>\n                </div>\n            </div>\n            <div class=\"chart-wrapper\">\n                <div id=\"micErrorBanner\" class=\"error-banner\">\n                    <i class=\"fas fa-microphone-slash\" style=\"font-size: 3rem; margin-bottom: 10px;\"></i>\n                    <h3>DISPOSITIVO DESCONECTADO</h3>\n                    <p>Reconecte el sensor de sonido al ESP32</p>\n                </div>\n                \n                <canvas id=\"soundChart\" style=\"width:100%; height:100%;\"></canvas>\n            </div>\n            <div id=\"digitalDeck\" class=\"digital-deck\" style=\"background:#000; border-radius:15px; padding:20px; display:flex; justify-content:space-between; align-items:center; border:3px solid #444; flex-shrink: 0; transition: 0.3s;\">\n                <div style=\"color:#00a8ff; font-family:'Orbitron';\">ADC INPUT</div>\n                <div id=\"digiVal\" style=\"color:#00ff00; font-family:'Orbitron'; font-size:2.5rem;\">0000</div>\n                <div style=\"color:#00a8ff; text-align:right;\">12-BIT</div>\n            </div>\n        </div>\n        \n        <div ng-show=\"view==='env'\" class=\"env-grid\">\n            <div class=\"env-col\">\n                <div id=\"cardPresencia\" class=\"env-card\" style=\"flex:2; position: relative;\">\n                    <div id=\"pirErrorBanner\" class=\"mini-error-banner\">\n                        <i class=\"fas fa-exclamation-triangle\"></i><span>PIR<br>DESCONECTADO</span>\n                    </div>\n                    <div class=\"env-title\">Monitor de Seguridad</div>\n                    <i id=\"iconPresencia\" class=\"fas big-icon\"></i>\n                    <div id=\"textPresencia\" class=\"status-badge\">--</div>\n                </div>\n                <div class=\"env-card\" style=\"background:#2f3640; color:white; flex:1\">\n                    <div class=\"env-title\" style=\"border-color:#444;\">Enlace</div>\n                    <div style=\"display:flex; gap:10px; align-items:center;\">\n                        <i class=\"fas fa-wifi\" style=\"color:var(--accent); font-size:1.5rem;\"></i>\n                        <div><div style=\"color:var(--accent); font-family:'Orbitron';\">ONLINE</div></div>\n                    </div>\n                </div>\n            </div>\n            <div class=\"env-col\">\n                <div id=\"cardDistancia\" class=\"env-card\" style=\"flex:1; position: relative;\">\n                    <div id=\"distErrorBanner\" class=\"mini-error-banner\">\n                        <i class=\"fas fa-satellite-dish\"></i><span>RADAR<br>DESCONECTADO</span>\n                    </div>\n                    <div class=\"env-title\">Radar Proximidad</div>\n                    <div><span id=\"valDistancia\" class=\"big-data\">--</span> <span id=\"unitDistancia\">cm</span></div>\n                    <div class=\"radar-bar-bg\"><div id=\"barDistancia\" class=\"radar-bar-fill\" style=\"width:0%\"></div></div>\n                </div>\n                <div id=\"cardZona\" class=\"env-card\" style=\"flex:1\">\n                    <div class=\"env-title\">Análisis Zona</div>\n                    <i id=\"iconZona\" class=\"fas big-icon\"></i>\n                    <div id=\"textZona\" style=\"font-weight:bold; font-size:1.3rem; margin-top:10px;\">--</div>\n                </div>\n            </div>\n            <div class=\"env-col\">\n                <div id=\"cardLdr\" class=\"env-card\" style=\"flex:1; position: relative;\">\n                    <div id=\"ldrErrorBanner\" class=\"mini-error-banner\">\n                        <i class=\"fas fa-lightbulb\"></i><span>LDR<br>DESCONECTADO</span>\n                    </div>\n                    <div class=\"env-title\">Iluminación</div>\n                    <i id=\"iconSol\" class=\"fas fa-lightbulb big-icon\"></i>\n                    <div style=\"margin-top:10px;\">\n                        <span id=\"valLuz\" class=\"big-data\">--</span> <span id=\"unitLuz\">%</span>\n                    </div>\n                </div>\n                <div class=\"env-card\" style=\"flex:1\">\n                    <div class=\"env-title\">Energía</div>\n                    <i id=\"iconEnergy\" class=\"fas fa-leaf big-icon\"></i>\n                    <div id=\"textEnergy\" style=\"font-weight:bold; font-size:1.1rem; margin-top:10px;\">--</div>\n                </div>\n            </div>\n        </div>\n        \n        <div ng-show=\"view==='sec'\" class=\"cam-layout\">\n            <div style=\"flex:3; display:flex; flex-direction:column; gap:15px; min-height: 0;\">\n                <div class=\"video-container\">\n                    <div class=\"video-overlay-status\"><div class=\"rec-dot\"></div><span>CAM-01 [LIVE]</span></div>\n                    <div id=\"alertOverlay\" class=\"overlay-alert\" ng-show=\"manualAlert\">ALARMA MANUAL</div>\n                    <div id=\"tamperOverlay\" class=\"overlay-alert\" style=\"background:rgba(0,0,0,0.9); border-color:red;\"><i class=\"fas fa-hand-paper\"></i> OBSTRUIDO</div>\n                    <div id=\"motionOverlay\" class=\"overlay-alert\"><i class=\"fas fa-running\"></i> MOVIMIENTO</div>\n                    <div id=\"soundOverlay\" class=\"overlay-alert\" style=\"background:rgba(231, 76, 60,0.9); border-color:white;\"><i class=\"fas fa-volume-up\"></i> RUIDO CRÍTICO</div>\n                    <div id=\"lightOverlay\" class=\"overlay-warning\"><i class=\"fas fa-low-vision\"></i> BAJA LUZ</div>\n                    <div id=\"flashEffect\" class=\"flash-effect\"></div>\n                    <div id=\"privacyCurtain\" class=\"privacy-curtain\" ng-show=\"privacyOn\">\n                        <i class=\"fas fa-user-secret\" style=\"font-size:4rem;\"></i><span>PRIVACIDAD</span>\n                    </div>\n                    <img id=\"stream_ia\" class=\"cam-image\" alt=\"Conectando cámara...\">\n                </div>\n                <div style=\"background:white; border-radius:15px; padding:15px; display:flex; justify-content:space-around; flex-shrink: 0;\">\n                    <button class=\"nav-btn\" ng-click=\"snap()\" style=\"background:#f1f2f6; color:#555;\"><i class=\"fas fa-camera\"></i> FOTO</button>\n                    <button class=\"nav-btn\" ng-click=\"togglePrivacy()\" style=\"background:#f1f2f6; color:#555;\"><i class=\"fas fa-user-slash\"></i> PRIVACIDAD</button>\n                    <button class=\"nav-btn\" ng-class=\"{'active-danger': manualAlert}\" style=\"color:#e74c3c; background:#ffebeb;\" ng-click=\"alarm()\"><i class=\"fas fa-bell\"></i> SIRENA</button>\n                </div>\n            </div>\n            <div style=\"flex:1; display:flex; flex-direction:column; gap:20px; min-height: 0;\">\n                <div class=\"ai-box\">\n                    <div class=\"env-title\" style=\"border-color:rgba(255,255,255,0.2); color:#bdc3c7;\">CONTROL AFORO</div>\n                    <div id=\"aiCounter\" class=\"big-data\" style=\"color:#00a8ff; margin:5px 0;\">0</div>\n                    <div id=\"aiStatus\" style=\"font-size:1rem; color:#f1c40f; font-weight:bold;\">SIN ACTIVIDAD</div>\n                </div>\n                <div class=\"log-box\">\n                    <div class=\"env-title\"><i class=\"fas fa-clipboard-list\"></i> Eventos</div>\n                    <div id=\"eventLog\" class=\"log-list\">\n                        <div class=\"log-item\" style=\"color:#2ecc71\"><i class=\"fas fa-power-off\"></i> Sistema Iniciado</div>\n                    </div>\n                </div>\n            </div>\n        </div>\n    </div>\n</div>\n\n<script>\n    (function(scope) {\n    scope.raw = { sound: 0, dist: 0, light: 0, pres: false };\n    scope.ui = {\n        audio: { pct: 0, alert: false, error: false },\n        env: { pres: {}, radar: 0, zona: {}, sun: {}, energy: {}, ldr_error: false, dist_error: false, pir_error: false },\n        security: { ai_count: 0, ai_status: \"SIN ACTIVIDAD\" }\n    };\n    scope.config = { sim: true };\n    scope.privacyOn = false;\n    scope.manualAlert = false;\n    \n    // Inyectar URL dinámica de la cámara IA\n    setTimeout(function() {\n        var camImg = document.getElementById('stream_ia');\n        if(camImg) camImg.src = 'http://' + window.location.hostname + ':5050/video_feed';\n    }, 1000);\n\n    var chartInstance = null;\n\n    scope.toggleSim = function() {\n        scope.send({ topic: \"sim_switch\", payload: scope.config.sim });\n    };\n\n    function addLog(text, type) {\n        var box = document.getElementById('eventLog');\n        if(!box) return;\n        var icon = \"fa-info-circle\"; var color = \"#3498db\";\n        if(type === 'crit') { icon = \"fa-exclamation-triangle\"; color = \"#e74c3c\"; }\n        if(type === 'cam') { icon = \"fa-camera\"; color = \"#8e44ad\"; }\n        if(type === 'priv') { icon = \"fa-user-secret\"; color = \"#bdc3c7\"; }\n        if(type === 'noise') { icon = \"fa-volume-up\"; color = \"#d63031\"; }\n        var item = document.createElement('div');\n        item.className = \"log-item\";\n        if(type==='crit' || type==='noise') item.classList.add('crit');\n        item.innerHTML = `<i class=\"fas ${icon}\" style=\"color:${color}\"></i> <span>${new Date().toLocaleTimeString()} - ${text}</span>`;\n        box.prepend(item);\n        if(box.children.length > 10) box.removeChild(box.lastChild);\n    }\n\n    function triggerFlash() {\n        var f = document.getElementById('flashEffect');\n        if(f) {\n            f.classList.remove('flash-anim');\n            void f.offsetWidth; \n            f.classList.add('flash-anim');\n        }\n    }\n\n    scope.togglePrivacy = function() { \n        scope.privacyOn = !scope.privacyOn; \n        document.getElementById('privacyCurtain').style.display = scope.privacyOn ? 'flex' : 'none';\n        addLog(scope.privacyOn ? \"Privacidad ON\" : \"Privacidad OFF\", \"priv\"); \n    };\n    \n    scope.snap = function() { \n        triggerFlash();\n        addLog(\"Captura Manual\", \"cam\"); \n    };\n    \n    scope.alarm = function() { \n        scope.manualAlert = !scope.manualAlert;\n        var statusText = scope.manualAlert ? \"SIRENA ACTIVADA\" : \"SIRENA APAGADA\";\n        addLog(statusText, \"crit\");\n        var cmd = scope.manualAlert ? \"ON\" : \"OFF\";\n        scope.send({ topic: \"buzzer_cmd\", payload: cmd });\n    };\n\n    setTimeout(function() {\n        var ctx = document.getElementById('soundChart');\n        if(ctx) {\n            chartInstance = new Chart(ctx, {\n                type: 'line',\n                data: {\n                    labels: Array(60).fill(''),\n                    datasets: [{\n                        label: 'Ruido (%)',\n                        data: Array(60).fill(0), \n                        borderColor: '#00a8ff', borderWidth: 3, \n                        backgroundColor: 'rgba(0, 168, 255, 0.1)', fill: true, \n                        pointRadius: 0, lineTension: 0.4 \n                    }]\n                },\n                options: {\n                    responsive: true, \n                    maintainAspectRatio: false, \n                    animation: { duration: 0 }, \n                    legend: { display: false },\n                    scales: {\n                        xAxes: [{ display: false }],\n                        yAxes: [{\n                            display: true,\n                            ticks: { \n                                min: 0, \n                                max: 100, \n                                suggestedMin: 0, \n                                suggestedMax: 100, \n                                beginAtZero: true, \n                                fontColor: '#888',\n                                stepSize: 20\n                            },\n                            gridLines: { color: '#444' }\n                        }]\n                    }\n                }\n            });\n        }\n    }, 500);\n\n    scope.$watch('msg.payload', function(newVal) {\n        if (!newVal) return;\n        if (newVal.raw) scope.raw = newVal.raw;\n        if (newVal.ui) scope.ui = newVal.ui;\n        if(newVal.config) scope.config.sim = newVal.config.sim;\n\n        var badge = document.getElementById('simBadge');\n        if(badge) badge.style.display = scope.config.sim ? 'block' : 'none';\n\n        // --- MANEJOS DE ERROR DE SENSORES ---\n        var micBanner = document.getElementById('micErrorBanner');\n        var deck = document.getElementById('digitalDeck');\n        var dv = document.getElementById('digiVal');\n        var vu = document.getElementById('vuBar');\n        \n        if(scope.ui.audio.error) {\n            if(micBanner) micBanner.style.display = 'block';\n            if(deck) deck.style.opacity = '0.3';\n            if(dv) { dv.innerText = \"ERROR\"; dv.style.color = \"#d63031\"; }\n            if(vu) vu.style.width = '0%';\n        } else {\n            if(micBanner) micBanner.style.display = 'none';\n            if(deck) deck.style.opacity = '1';\n            if(dv) { dv.innerText = scope.raw.sound; dv.style.color = \"#00ff00\"; }\n            if(vu) vu.style.width = scope.ui.audio.pct + '%';\n        }\n\n        var pirBanner = document.getElementById('pirErrorBanner');\n        if(scope.ui.env.pir_error) { if(pirBanner) pirBanner.style.display = 'flex'; }\n        else { if(pirBanner) pirBanner.style.display = 'none'; }\n\n        var distBanner = document.getElementById('distErrorBanner');\n        if(scope.ui.env.dist_error) { if(distBanner) distBanner.style.display = 'flex'; }\n        else { if(distBanner) distBanner.style.display = 'none'; }\n\n        var ldrBanner = document.getElementById('ldrErrorBanner');\n        if(scope.ui.env.ldr_error) { if(ldrBanner) ldrBanner.style.display = 'flex'; }\n        else { if(ldrBanner) ldrBanner.style.display = 'none'; }\n\n        // ------------------------------------\n\n        var siren = document.getElementById('siren');\n        if(siren) {\n            if(scope.ui.audio.alert && !scope.ui.audio.error) siren.classList.add('alert');\n            else siren.classList.remove('alert');\n        }\n        \n        if(chartInstance) {\n            var val_to_plot = scope.ui.audio.error ? 0 : scope.ui.audio.pct;\n            chartInstance.data.datasets[0].data.push(val_to_plot);\n            chartInstance.data.datasets[0].data.shift();\n            if(scope.view === 'audio') chartInstance.update();\n        }\n\n        var cp = document.getElementById('cardPresencia');\n        var ip = document.getElementById('iconPresencia');\n        var tp = document.getElementById('textPresencia');\n        if(cp) {\n            cp.className = \"env-card \" + scope.ui.env.pres.class;\n            ip.className = \"fas big-icon \" + scope.ui.env.pres.icon;\n            ip.style.color = scope.ui.env.pres.color;\n            tp.innerText = scope.ui.env.pres.text;\n            tp.style.background = scope.ui.env.pres.color;\n        }\n\n        var vd = document.getElementById('valDistancia');\n        if(vd) vd.innerText = scope.raw.dist;\n        var bd = document.getElementById('barDistancia');\n        if(bd) bd.style.width = scope.ui.env.radar + '%';\n\n        var cz = document.getElementById('cardZona');\n        var iz = document.getElementById('iconZona');\n        var tz = document.getElementById('textZona');\n        if(cz) {\n            cz.style.borderLeft = \"5px solid \" + scope.ui.env.zona.border;\n            iz.className = \"fas big-icon \" + scope.ui.env.zona.icon;\n            iz.style.color = scope.ui.env.zona.color;\n            tz.innerText = scope.ui.env.zona.text;\n            tz.style.color = scope.ui.env.zona.color;\n        }\n        \n        var vl = document.getElementById('valLuz');\n        if(vl) vl.innerText = scope.raw.light;\n        var isol = document.getElementById('iconSol');\n        if(isol) {\n            isol.style.color = scope.ui.env.sun.color;\n            isol.style.textShadow = scope.ui.env.sun.shadow;\n        }\n\n        var te = document.getElementById('textEnergy');\n        var ie = document.getElementById('iconEnergy');\n        if(te) {\n            te.innerText = scope.ui.env.energy.text;\n            ie.style.color = scope.ui.env.energy.color;\n        }\n\n        var mo = document.getElementById('motionOverlay');\n        var to = document.getElementById('tamperOverlay');\n        var lo = document.getElementById('lightOverlay');\n        var so = document.getElementById('soundOverlay');\n        \n        if(!scope.privacyOn) {\n            if(mo) mo.style.display = scope.raw.pres ? 'block' : 'none';\n            if(to) to.style.display = scope.ui.env.zona.tamper ? 'block' : 'none';\n            if(lo) lo.style.display = scope.ui.env.sun.low_light ? 'block' : 'none';\n            \n            if(scope.ui.audio.alert && !scope.ui.audio.error) {\n                if(so) {\n                    so.style.display = 'block';\n                    setTimeout(() => so.style.display = 'none', 1500);\n                }\n                if(!scope.lastSoundAlert) {\n                    scope.lastSoundAlert = true;\n                    setTimeout(() => scope.lastSoundAlert = false, 2000);\n                }\n            }\n        }\n\n        var aic = document.getElementById('aiCounter');\n        if(aic) aic.innerText = scope.ui.security.ai_count;\n        var ais = document.getElementById('aiStatus');\n        if(ais) ais.innerText = scope.ui.security.ai_status;\n    });\n})(scope);\n</script>",
