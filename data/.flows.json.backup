    {
        "id": "26b303ae4521b1ad",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "Emparejar Tabla Custom",
        "func": "delete msg.socketid;\ndelete msg._socketid;\n\nvar historyMap = flow.get(\"sc5_history\") || [];\n\nif (msg.payload === \"reset_command_internal\") {\n    historyMap = [];\n    flow.set(\"sc5_history\", historyMap);\n    msg.payload = [];\n    return msg;\n}\n\nvar emotion = msg.payload;\nvar lastInput = flow.get(\"last_input_sentence\");\n\nif (emotion && lastInput) {\n    historyMap.unshift({\n        \"oracion\": lastInput,\n        \"emocion\": emotion\n    });\n    \n    if (historyMap.length > 50) historyMap.pop();\n    flow.set(\"sc5_history\", historyMap);\n    \n    msg.payload = historyMap;\n    flow.set(\"last_input_sentence\", null);\n    return msg;\n}\nreturn null;",
        "outputs": 1,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 510,
        "y": 980,
        "wires": [
            [
                "9cb5e6068538c0b3"
            ]
        ]
    },
    {
        "id": "9cb5e6068538c0b3",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "5fe68977a9bfa8ed",
        "name": "Tabla HTML Custom (100% Responsiva)",
        "order": 1,
        "width": "0",
        "height": "0",
        "format": "<style>\n    .custom-table-container {\n        width: 100%;\n        max-height: 450px;\n        overflow-y: auto;\n        background: #fff;\n        border-radius: 8px;\n        box-shadow: 0 4px 6px rgba(0,0,0,0.1);\n    }\n    .custom-table {\n        width: 100%;\n        border-collapse: collapse;\n        font-family: 'Roboto', sans-serif;\n    }\n    .custom-table th {\n        background: #2980b9;\n        color: white;\n        padding: 12px;\n        text-align: left;\n        position: sticky;\n        top: 0;\n        z-index: 1;\n    }\n    .custom-table td {\n        padding: 12px;\n        border-bottom: 1px solid #ecf0f1;\n        color: #2c3e50;\n    }\n    .custom-table tr:nth-child(even) {\n        background-color: #f8f9fa;\n    }\n    .custom-table tr:hover {\n        background-color: #e8f4f8;\n    }\n</style>\n\n<div class=\"custom-table-container\">\n    <table class=\"custom-table\">\n        <thead>\n            <tr>\n                <th>Oración Ingresada</th>\n                <th>Emoción</th>\n            </tr>\n        </thead>\n        <tbody>\n            <tr ng-repeat=\"row in msg.payload track by $index\">\n                <td>{{row.oracion}}</td>\n                <td style=\"font-weight: bold; font-size: 1.1em;\">{{row.emocion}}</td>\n            </tr>\n            <tr ng-if=\"!msg.payload.length\">\n                <td colspan=\"2\" style=\"text-align: center; color: #95a5a6; padding: 20px;\">\n                    <i class=\"fa fa-history\"></i> Aún no hay participaciones.\n                </td>\n            </tr>\n        </tbody>\n    </table>\n</div>",
        "storeOutMessages": true,
        "fwdInMessages": true,
        "resendOnRefresh": true,
        "templateScope": "local",
