    {
        "id": "93b5a84bbc676d8c",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "CEREBRO AI (Python -> JS)",
        "func": "// --- 1. GESTIÓN DE ESTADO ---\nvar params = context.get('params') || { light_threshold: 30, pir_weight: 60 };\nvar sim_active = context.get('sim_active');\nif (sim_active === undefined) sim_active = true;\n\nvar t = context.get('t') || 0;\n\n// --- 2. ENTRADAS DE CONTROL (UI) ---\nif (msg.topic === \"update_params\") {\n    params = msg.payload;\n    context.set('params', params);\n}\n\nif (msg.topic === \"sim_switch\") {\n    sim_active = msg.payload;\n    context.set('sim_active', sim_active);\n    return { \n        payload: { \n            config: { sim: sim_active, params: params },\n            sensors: { pir: false, light: 0, sound: 0, sound_pct: 0 }, \n            prediction: { class: 0, prob: 0 }\n        } \n    };\n}\n\n// --- 3. PROCESAMIENTO DE DATOS (RELOJ vs MQTT) ---\nvar s_pir = false; \nvar s_light = 0; \nvar s_sound = 0;\nvar data_valid = false;\n\nif (sim_active) {\n    if (msg.payload.luz_percent !== undefined) return null;\n    \n    t += 0.2; \n    context.set('t', t);\n    \n    var is_busy = Math.sin(t * 0.5) > 0;\n    if (is_busy) {\n        s_pir = Math.random() > 0.3;\n        s_light = Math.floor(Math.random() * 40) + 50;\n        s_sound = Math.floor(Math.random() * 2000) + 1000;\n    } else {\n        s_pir = false;\n        s_light = Math.floor(Math.random() * 20);\n        s_sound = Math.floor(Math.random() * 600) + 200;\n    }\n    data_valid = true;\n\n} else {\n    if (msg.payload.luz_percent !== undefined) {\n        s_pir = msg.payload.presencia || false;\n        s_light = msg.payload.luz_percent || 0;\n        s_sound = msg.payload.sound_bruto || 0;\n        data_valid = true;\n    } \n}\n\nif (!data_valid) return null;\n\n// Convertir sonido crudo a porcentaje (0-100%)\nvar s_sound_pct = ((s_sound / 4095.0) * 100).toFixed(1);\n\n// --- 4. ALGORITMO PREDICCIÓN ---\nvar light_score = Math.min(s_light / 100.0, 1.0);\nvar sound_score = Math.min(s_sound / 4095.0, 1.0);\nvar pir_score = s_pir ? 1.0 : 0.0;\n\nvar w_pir = params.pir_weight / 100.0;\nvar w_light = 0.3;\nvar w_sound = 0.1;\n\nvar score = (pir_score * w_pir) + (light_score * w_light) + (sound_score * w_sound);\n\n// Penalización por oscuridad\nif (s_light < params.light_threshold) {\n    score -= 0.4;\n}\n\nvar probability = Math.min(Math.max(score, 0.0), 1.0);\nvar pred_class = probability > 0.5 ? 1 : 0;\nvar prob_pct = (probability * 100).toFixed(1);\n\n// --- 5. SALIDA ---\nmsg.payload = {\n    sensors: {\n        pir: s_pir,\n        light: s_light,\n        sound: s_sound,\n        sound_pct: s_sound_pct \n    },\n    prediction: {\n        class: pred_class,\n        prob: prob_pct\n    },\n    config: {\n        sim: sim_active,\n        params: params\n    }\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
