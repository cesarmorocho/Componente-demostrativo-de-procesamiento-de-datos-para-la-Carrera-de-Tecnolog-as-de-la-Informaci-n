    {
        "id": "76aba16bd3d9509b",
        "type": "ui_template",
        "z": "0b3362ab9d38a37d",
        "group": "group_esc3_main",
        "name": "UI SC3 - PREDICCIÓN AI",
        "order": 1,
        "width": "24",
        "height": "12",
        "format": "<!DOCTYPE html>\n<script src=\"https://cdn.jsdelivr.net/npm/chart.js\"></script>\n<link href=\"https://fonts.googleapis.com/css2?family=Orbitron:wght@500&family=Rajdhani:wght@500;700&family=Roboto:wght@300;400;700&display=swap\" rel=\"stylesheet\">\n<link rel=\"stylesheet\" href=\"https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css\">\n\n<style>\n    :root { --primary-bg: #ecf0f1; --accent: #2980b9; --success: #27ae60; --danger: #c0392b; --warning: #f39c12; --text-dark: #2c3e50; }\n    .main-container { display: flex; height: 100%; font-family: 'Roboto', sans-serif; background-color: var(--primary-bg); color: var(--text-dark); overflow: hidden; width: 100%; position: absolute; top:0; left:0; }\n    .content-area { flex: 1; padding: 20px; overflow-y: auto; height: 100%; box-sizing: border-box; width: 100%; }\n\n    /* --- LAYOUT RESPONSIVE FLEXBOX --- */\n    .sc3-layout { \n        display: flex; \n        flex-wrap: wrap; \n        gap: 20px; \n        padding: 10px; \n        align-items: stretch; \n        min-height: 100%; \n    }\n    \n    /* Panel Izquierdo (Predicción) */\n    .pred-panel { \n        flex: 1 1 350px; \n        background: white; \n        border-radius: 15px; \n        padding: 30px 20px; \n        display: flex; \n        flex-direction: column; \n        align-items: center; \n        justify-content: center; \n        box-shadow: 0 5px 15px rgba(0,0,0,0.05); \n        text-align: center; \n        position: relative; \n        min-height: 450px; \n        box-sizing: border-box; \n        border: 1px solid #e0e0e0;\n    }\n    \n    .pred-circle { width: 220px; height: 220px; border-radius: 50%; display: flex; flex-direction: column; align-items: center; justify-content: center; border: 10px solid #eee; transition: 0.5s; margin-bottom: 20px; }\n    .pred-circle.occupied { border-color: var(--danger); background: rgba(192, 57, 43, 0.1); }\n    .pred-circle.empty { border-color: var(--success); background: rgba(39, 174, 96, 0.1); }\n    .pred-label { font-size: 3rem; font-family: 'Rajdhani'; font-weight: bold; }\n    \n    .prob-bar-bg { width: 80%; height: 20px; background: #eee; border-radius: 10px; overflow: hidden; margin-top: 10px; }\n    .prob-bar-fill { height: 100%; width: 0%; background: linear-gradient(90deg, var(--success), var(--warning), var(--danger)); transition: 0.3s; }\n\n    /* Columna Derecha (Datos y Controles) */\n    .right-col { \n        flex: 1 1 450px; \n        display: flex; \n        flex-direction: column; \n        gap: 20px; \n    }\n    .data-card { background: white; border-radius: 15px; padding: 20px; box-shadow: 0 5px 10px rgba(0,0,0,0.05); border: 1px solid #e0e0e0;}\n    \n    /* Grilla de Sensores */\n    .sensor-grid { display: flex; flex-wrap: wrap; gap: 10px; margin-bottom: 10px; justify-content: space-between;}\n    .sensor-box { background: #f8f9fa; padding: 15px; border-radius: 8px; text-align: center; border: 1px solid #eee; flex: 1 1 30%; min-width: 100px;}\n    .s-val { font-size: 1.4rem; font-weight: bold; color: var(--accent); font-family: 'Orbitron'; margin-top:5px;}\n    \n    /* Sliders */\n    .slider-row { margin-bottom: 20px; }\n    .slider-info { display: flex; justify-content: space-between; font-size: 0.9rem; color: #7f8c8d; margin-bottom: 5px; font-weight: bold; }\n    input[type=range] { width: 100%; cursor: pointer; accent-color: var(--warning); }\n    \n    /* Chart Container */\n    .chart-container { position: relative; flex: 1; min-height: 250px; width: 100%; }\n    .sim-overlay { position: absolute; top: 10px; right: 10px; background: var(--warning); color: white; padding: 5px 10px; border-radius: 5px; font-weight: bold; font-size: 0.7rem; z-index:10;}\n</style>\n\n<div class=\"main-container\">\n    <div class=\"content-area\">\n        <div class=\"sc3-layout\">\n            \n            <div class=\"pred-panel\">\n                <div class=\"sim-overlay\" ng-show=\"config.sim\">SIMULACIÓN</div>\n                <div style=\"font-family: 'Rajdhani'; color: var(--text-dark); margin-bottom: 20px; font-size: 1.4rem; font-weight: bold;\">\n                    MODELO DE PREDICCIÓN (IA)\n                </div>\n                \n                <div class=\"pred-circle\" ng-class=\"prediction.class === 1 ? 'occupied' : 'empty'\">\n                    <i class=\"fas\" style=\"font-size: 5rem;\" \n                       ng-class=\"prediction.class === 1 ? 'fa-users' : 'fa-door-open'\"\n                       ng-style=\"{color: prediction.class === 1 ? '#c0392b' : '#27ae60'}\"></i>\n                </div>\n                \n                <div class=\"pred-label\" ng-style=\"{color: prediction.class === 1 ? '#c0392b' : '#27ae60'}\">\n                    {{prediction.class === 1 ? 'OCUPADA' : 'VACÍA'}}\n                </div>\n                \n                <div style=\"width: 100%; text-align: center; margin-top: 30px;\">\n                    <div style=\"display: flex; justify-content: space-between; width: 80%; margin: 0 auto; font-size: 0.8rem; color: #7f8c8d;\">\n                        <span>Prob. Vacío</span><span>Prob. Ocupado</span>\n                    </div>\n                    <div class=\"prob-bar-bg\">\n                        <div class=\"prob-bar-fill\" style=\"width: {{prediction.prob}}%\"></div>\n                    </div>\n                    <div style=\"font-weight: bold; margin-top: 10px; font-family: 'Orbitron'; font-size: 1.2rem; color: var(--text-dark);\">\n                        {{prediction.prob}}% Probabilidad\n                    </div>\n                </div>\n            </div>\n\n            <div class=\"right-col\">\n                \n                <div class=\"data-card\">\n                    <div style=\"display:flex; justify-content:space-between; align-items:center; border-bottom: 2px solid #f0f0f0; padding-bottom: 10px; margin-bottom: 15px;\">\n                        <h4 style=\"margin:0; color: var(--accent); font-family: 'Rajdhani'; font-size: 1.2rem;\"><i class=\"fas fa-microchip\"></i> INPUTS DEL MODELO (X)</h4>\n                        <div style=\"display:flex; align-items:center; gap:5px; font-size:0.8rem; font-weight:bold; color:#7f8c8d;\">\n                            <span>Simulación:</span>\n                            <md-switch ng-model=\"config.sim\" aria-label=\"Sim\" ng-change=\"toggleSim()\" style=\"margin:0\"></md-switch>\n                        </div>\n                    </div>\n                    \n                    <div class=\"sensor-grid\">\n                        <div class=\"sensor-box\">\n                            <div style=\"font-size: 0.8rem; color:#7f8c8d; font-weight:bold;\">MOVIMIENTO (PIR)</div>\n                            <div class=\"s-val\" ng-style=\"{color: sensors.pir ? '#c0392b' : '#27ae60'}\">\n                                {{sensors.pir ? 'DETECTADO' : 'QUIETO'}}\n                            </div>\n                        </div>\n                        <div class=\"sensor-box\">\n                            <div style=\"font-size: 0.8rem; color:#7f8c8d; font-weight:bold;\">LUZ (LDR)</div>\n                            <div class=\"s-val\" style=\"color: #f39c12;\">{{sensors.light}}%</div>\n                        </div>\n                        <div class=\"sensor-box\">\n                            <div style=\"font-size: 0.8rem; color:#7f8c8d; font-weight:bold;\">SONIDO (MIC)</div>\n                            <div class=\"s-val\" style=\"color: #8e44ad;\">{{sensors.sound_pct}}%</div>\n                        </div>\n                    </div>\n                </div>\n\n                <div class=\"data-card\" style=\"flex: 1; display: flex; flex-direction: column; min-height: 280px;\">\n                    <h4 style=\"margin: 0 0 10px 0; color: var(--text-dark); font-family:'Rajdhani';\"><i class=\"fas fa-project-diagram\"></i> MINERÍA DE PATRONES (SCATTER)</h4>\n                    <div class=\"chart-container\">\n                        <canvas id=\"scatterChart\"></canvas>\n                    </div>\n                </div>\n\n                <div class=\"data-card\" style=\"background: #fdfdfd;\">\n                    <h4 style=\"margin: 0 0 15px 0; color: var(--warning); font-family:'Rajdhani';\"><i class=\"fas fa-sliders-h\"></i> ENTRENAMIENTO: AJUSTAR PARÁMETROS</h4>\n                    \n                    <div class=\"slider-row\">\n                        <div class=\"slider-info\">\n                            <span>Umbral Penalización de Luz (Si es menor, asume que no hay nadie)</span>\n                            <span style=\"color: var(--accent);\">{{config.params.light_threshold}}%</span>\n                        </div>\n                        <input type=\"range\" min=\"0\" max=\"100\" ng-model=\"config.params.light_threshold\" ng-change=\"updateParams()\" \n                               ng-mousedown=\"startDrag()\" ng-mouseup=\"stopDrag()\" ng-touchstart=\"startDrag()\" ng-touchend=\"stopDrag()\">\n                    </div>\n                    \n                    <div class=\"slider-row\">\n                        <div class=\"slider-info\">\n                            <span>Peso del Movimiento PIR (Qué tan importante es la presencia)</span>\n                            <span style=\"color: var(--accent);\">{{config.params.pir_weight}}%</span>\n                        </div>\n                        <input type=\"range\" min=\"0\" max=\"100\" ng-model=\"config.params.pir_weight\" ng-change=\"updateParams()\"\n                               ng-mousedown=\"startDrag()\" ng-mouseup=\"stopDrag()\" ng-touchstart=\"startDrag()\" ng-touchend=\"stopDrag()\">\n                    </div>\n                </div>\n\n            </div>\n        </div>\n    </div>\n</div>\n\n<script>\n(function(scope) {\n    scope.sensors = { pir: false, light: 0, sound: 0, sound_pct: 0 };\n    scope.prediction = { class: 0, prob: 0 };\n    scope.config = { sim: true, params: { light_threshold: 30, pir_weight: 60 } };\n    \n    var scatterChart = null;\n    var isDragging = false;\n\n    scope.updateParams = function() {\n        scope.send({ topic: \"update_params\", payload: scope.config.params });\n    };\n    \n    scope.toggleSim = function() {\n        scope.send({ topic: \"sim_switch\", payload: scope.config.sim });\n    };\n\n    scope.startDrag = function() { isDragging = true; };\n    scope.stopDrag = function() { isDragging = false; scope.updateParams(); };\n\n    setTimeout(function() {\n        var ctx = document.getElementById('scatterChart');\n        if(ctx) {\n            // CÓDIGO COMPATIBLE CON CHART.JS V2 (VERSIÓN OFFLINE DE NODE-RED)\n            scatterChart = new Chart(ctx, {\n                type: 'scatter',\n                data: {\n                    datasets: [{\n                        label: 'Historial',\n                        data: [],\n                        backgroundColor: [],\n                        pointRadius: 6,\n                        pointHoverRadius: 9,\n                        borderColor: 'rgba(255,255,255,0.8)',\n                        borderWidth: 1,\n                        fill: false,       // Evita sombreados verdes\n                        showLine: false    // Evita lineas conectoras\n                    }]\n                },\n                options: {\n                    responsive: true,\n                    maintainAspectRatio: false,\n                    animation: { duration: 0 }, \n                    legend: { display: true, position: 'top' }, // Leyenda superior\n                    scales: {\n                        xAxes: [{\n                            ticks: { min: 0, max: 100, fontColor: '#7f8c8d' },\n                            gridLines: { color: '#f0f0f0' },\n                            scaleLabel: { \n                                display: true, \n                                labelString: 'Nivel de Luz (%)', \n                                fontColor: '#7f8c8d', \n                                fontStyle: 'bold',\n                                fontFamily: 'Rajdhani'\n                            }\n                        }],\n                        yAxes: [{\n                            ticks: { min: 0, max: 100, fontColor: '#7f8c8d' },\n                            gridLines: { color: '#f0f0f0' },\n                            scaleLabel: { \n                                display: true, \n                                labelString: 'Nivel de Sonido (%)', \n                                fontColor: '#7f8c8d', \n                                fontStyle: 'bold',\n                                fontFamily: 'Rajdhani'\n                            }\n                        }]\n                    }\n                }\n            });\n        }\n    }, 500);\n\n    scope.$watch('msg.payload', function(newVal) {\n        if (!newVal) return;\n\n        scope.sensors = newVal.sensors || { pir: false, light: 0, sound: 0, sound_pct: 0 };\n        scope.prediction = newVal.prediction || { class: 0, prob: 0 };\n        \n        if(newVal.config && !isDragging) {\n             scope.config = newVal.config;\n        }\n\n        if (scatterChart && newVal.sensors) {\n            var dataset = scatterChart.data.datasets[0];\n            \n            // Guardar el valor en PORCENTAJE (eje Y)\n            dataset.data.push({ x: newVal.sensors.light, y: newVal.sensors.sound_pct });\n            \n            var color = newVal.prediction.class === 1 ? 'rgba(192, 57, 43, 0.8)' : 'rgba(39, 174, 96, 0.8)';\n            dataset.backgroundColor.push(color);\n\n            if(dataset.data.length > 30) {\n                dataset.data.shift();\n                dataset.backgroundColor.shift();\n            }\n            scatterChart.update();\n        }\n    });\n})(scope);\n</script>",
