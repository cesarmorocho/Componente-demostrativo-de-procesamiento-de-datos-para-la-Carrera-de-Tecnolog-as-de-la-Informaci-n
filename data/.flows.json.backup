    {
        "id": "0cae06f630a35fdb",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "Enrutar Datos",
        "func": "var input = \"\";\n\nif (typeof msg.payload === \"object\" && msg.payload.palabra) {\n    input = msg.payload.palabra;\n} else if (typeof msg.payload === \"string\") {\n    input = msg.payload;\n}\n\nif (input.trim() !== \"\") {\n    flow.set(\"last_input_sentence\", input);\n    msg.payload = input;\n    \n    // MAGIA DE SINCRONIZACIÓN: Destruimos la etiqueta privada para que sea público\n    delete msg.socketid;\n    delete msg._socketid;\n    \n    return [msg, msg];\n}\nreturn [null, null];",
        "outputs": 2,
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 440,
        "y": 1060,
        "wires": [
            [
                "295fc0c365fbc93f",
                "aa573cc79a6703eb"
            ],
            [
                "f781e87e9a6fe86a"
            ]
        ]
    },
    {
        "id": "295fc0c365fbc93f",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "Procesador Nube Palabras",
        "func": "delete msg.socketid;\ndelete msg._socketid;\n\nvar wordMap = flow.get(\"sc5_wordMap\") || {};\nvar input = msg.payload;\nvar colors = [\"#2980b9\", \"#27ae60\", \"#8e44ad\", \"#f39c12\", \"#d35400\", \"#16a085\", \"#1abc9c\"];\n\nif (input === \"reset_command_internal\") {\n    wordMap = {}; \n    flow.set(\"sc5_wordMap\", wordMap);\n    msg.payload = [];\n    return msg;\n}\n\nif (typeof input === 'string' && input.trim() !== '') {\n    var words = input.toLowerCase().replace(/[^a-zA-Z0-9 áéíóúñ]/g, \"\").split(\" \");\n    words.forEach(function(w) {\n        if (w.trim() !== \"\") { \n            if (wordMap[w]) wordMap[w].count++;\n            else {\n                var rndColor = colors[Math.floor(Math.random() * colors.length)];\n                wordMap[w] = { count: 1, color: rndColor };\n            }\n        }\n    });\n    flow.set(\"sc5_wordMap\", wordMap);\n}\n\nvar maxCount = 1;\nfor (var k in wordMap) {\n    if (wordMap[k].count > maxCount) maxCount = wordMap[k].count;\n}\n\nvar result = [];\nfor (var key in wordMap) {\n    var scale = wordMap[key].count / maxCount; \n    var size = 15 + (scale * 50); \n    result.push({ word: key, size: size + \"px\", color: wordMap[key].color, count: wordMap[key].count });\n}\n\nresult.sort(function(a, b) { return b.count - a.count; });\nmsg.payload = result.slice(0, 45);\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 880,
        "y": 860,
        "wires": [
            [
                "dfc12ac8d6e94510"
            ]
        ]
    },
    {
        "id": "c39ce9ce2a3323a2",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "Procesador Emociones NLP",
        "func": "delete msg.socketid;\ndelete msg._socketid;\n\nvar emotionMap = flow.get(\"sc5_emotionMap\") || {\n    \"Feliz 😄\": { count: 0, color: \"#27ae60\" },\n    \"Triste 😢\": { count: 0, color: \"#2980b9\" },\n    \"Enojado 😡\": { count: 0, color: \"#c0392b\" },\n    \"Sorprendido 😲\": { count: 0, color: \"#8e44ad\" },\n    \"Neutro 😐\": { count: 0, color: \"#7f8c8d\" }\n};\n\nvar input = msg.payload;\n\nif (input === \"reset_command_internal\") {\n    for(var k in emotionMap) emotionMap[k].count = 0;\n    flow.set(\"sc5_emotionMap\", emotionMap);\n    msg.payload = [];\n    return msg;\n}\n\nif (emotionMap[input] !== undefined) {\n    emotionMap[input].count++;\n    flow.set(\"sc5_emotionMap\", emotionMap);\n}\n\nvar maxCount = 1;\nfor (var k in emotionMap) {\n    if (emotionMap[k].count > maxCount) maxCount = emotionMap[k].count;\n}\n\nvar result = [];\nfor (var key in emotionMap) {\n    if (emotionMap[key].count > 0) {\n        var scale = emotionMap[key].count / maxCount;\n        var size = 20 + (scale * 30); \n        result.push({ word: key, size: size + \"px\", color: emotionMap[key].color, count: emotionMap[key].count });\n    }\n}\n\nresult.sort(function(a, b) { return b.count - a.count; });\nmsg.payload = result;\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 880,
        "y": 1040,
        "wires": [
            [
                "54e03e80521f0f7c"
            ]
        ]
    },
