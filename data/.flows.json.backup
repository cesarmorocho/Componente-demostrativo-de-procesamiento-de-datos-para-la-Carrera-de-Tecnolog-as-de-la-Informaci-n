    {
        "id": "exec_leer_ram",
        "type": "exec",
        "z": "d8dc90e837e21ab6",
        "command": "cat /proc/meminfo",
        "addpay": false,
        "append": "",
        "useSpawn": "false",
        "timer": "",
        "winHide": false,
        "oldrc": false,
        "name": "Leer RAM",
        "x": 540,
        "y": 200,
        "wires": [
            [
                "func_procesar_cpu_ram"
            ],
            [],
            []
        ]
