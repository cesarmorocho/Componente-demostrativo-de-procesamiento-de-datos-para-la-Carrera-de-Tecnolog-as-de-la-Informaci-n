    {
        "id": "func_procesar_cpu_ram",
        "type": "function",
        "z": "d8dc90e837e21ab6",
        "name": "Procesar y Armar CSV",
        "func": "var outCpu = msg.cpu_data || \"\";\nvar outRam = msg.payload || \"\";\n\n// 1. Procesar CPU\nvar cpuVal = 0;\ntry {\n    var lines = outCpu.split('\\n');\n    var cpuLine = \"\";\n    for(var i=0; i<lines.length; i++){\n        if(lines[i].toLowerCase().includes('cpu')){\n            cpuLine = lines[i]; break;\n        }\n    }\n    var idle = 100;\n    var matchId = cpuLine.match(/([0-9.,]+)\\s*%?\\s*id/i);\n    if(matchId) {\n        idle = parseFloat(matchId[1].replace(',','.'));\n        cpuVal = Math.round(100 - idle);\n    }\n} catch(e) {}\n\n// 2. Procesar RAM\nvar ramVal = 0;\ntry {\n    var matchTotal = outRam.match(/MemTotal:\\s+(\\d+)/);\n    var matchAvail = outRam.match(/MemAvailable:\\s+(\\d+)/) || outRam.match(/MemFree:\\s+(\\d+)/);\n    if(matchTotal && matchAvail){\n        var total = parseInt(matchTotal[1]);\n        var avail = parseInt(matchAvail[1]);\n        ramVal = Math.round(((total - avail) / total) * 100);\n    }\n} catch(e) {}\n\n// 3. Formatear Fecha Local\nvar d = new Date();\nvar tzOffset = d.getTimezoneOffset() * 60000;\nvar localISOTime = (new Date(d - tzOffset)).toISOString().slice(0, -1);\nvar fechaStr = localISOTime.split('T')[0] + \" \" + localISOTime.split('T')[1].split('.')[0];\n\n// 4. Limpiar nombre del escenario\nvar escenario = msg.nombre_escenario;\nif (!escenario || escenario.trim() === \"\") {\n    escenario = \"Desconocido\";\n} else {\n    escenario = escenario.trim();\n}\n\nmsg.payload = {\n    \"Fecha_Hora\": fechaStr,\n    \"Escenario\": escenario,\n    \"CPU_Porcentaje\": cpuVal,\n    \"RAM_Porcentaje\": ramVal\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 780,
        "y": 200,
        "wires": [
