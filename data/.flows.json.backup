        "format": "<div style=\"\n    display: flex; \n    flex-wrap: wrap; \n    justify-content: center; \n    align-content: flex-start;\n    height: 100%; \n    width: 100%;\n    overflow-y: auto;\n    overflow-x: hidden;\n    background: white;\n    border-radius: 10px;\n    padding: 20px;\n    border: 1px solid #eee;\n    box-sizing: border-box;\n\">\n    <div ng-repeat=\"item in msg.payload track by $index\" \n         style=\"\n            margin: 10px; \n            font-weight: bold;\n            font-family: 'Rajdhani', sans-serif;\n            transition: all 0.5s ease;\n            font-size: {{item.size}};\n            color: {{item.color}};\n            text-shadow: 1px 1px 2px rgba(0,0,0,0.1);\n            text-align: center;\n            word-wrap: break-word;\n         \">\n        {{item.word}}\n    </div>\n    \n    <div ng-if=\"!msg.payload.length\" style=\"color: #bdc3c7; font-size: 1.2rem; font-family: 'Rajdhani'; font-weight:bold; margin-top:20%;\">\n        <i class=\"fas fa-comment-dots\"></i> Esperando palabras...\n    </div>\n</div>",
