    {
        "id": "9714e1cdf8ebf83b",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "CEREBRO SC4 (Domótica)",
        "func": "// --- 1. GESTIÓN DE ESTADO (MEMORIA PERSISTENTE) ---\n// Se guardan los valores en memoria para no perderlos en cada ciclo de reloj\nvar state = context.get('state') || { \n    light: 50, \n    sound: 15, // AHORA SE MIDE EN PORCENTAJE (0 a 100)\n    presence: true,\n    light_status: false, \n    ac_status: false, \n    timer_idle: 0 \n};\n\nvar sim_active = context.get('sim_active');\nif (sim_active === undefined) sim_active = true;\n\n// --- 2. ENTRADAS DE CONTROL (UI MANUAL) ---\n// Permite al usuario manipular los sliders en la web durante la simulación\nif (msg.topic === \"update_inputs\") {\n    state.light = parseInt(msg.payload.light);\n    state.sound = parseInt(msg.payload.sound);\n    state.presence = msg.payload.presence;\n    if(state.presence) state.timer_idle = 0; // Resetea el temporizador si detecta a alguien\n    context.set('state', state);\n}\n\n// Interrumpe el flujo si el mensaje es solo para cambiar entre Modo Simulación/Real\nif (msg.topic === \"sim_switch\") {\n    sim_active = msg.payload;\n    context.set('sim_active', sim_active);\n    return { \n        payload: { \n            config: { sim: sim_active }, \n            inputs: state, \n            actuators: { light: state.light_status, ac: state.ac_status } \n        } \n    };\n}\n\n// --- 3. PROCESAMIENTO DE DATOS ---\nif (sim_active) {\n    // MODO SIMULACIÓN: Ignoramos los datos físicos del ESP32 si llegan\n    if (msg.payload.sound_bruto !== undefined) return null;\n    \n    // Generamos fluctuaciones aleatorias leves para dar realismo a la gráfica\n    if (msg.topic !== \"update_inputs\") {\n        state.light += Math.floor(Math.random() * 7) - 3; \n        state.light = Math.max(0, Math.min(100, state.light)); // Mantiene límite entre 0-100%\n        \n        state.sound += Math.floor(Math.random() * 5) - 2;\n        state.sound = Math.max(0, Math.min(100, state.sound)); // Mantiene límite entre 0-100%\n        \n        if (Math.random() < 0.02) state.presence = !state.presence;\n    }\n} else {\n    // MODO REAL: Tomamos los valores directos del microcontrolador ESP32\n    if (msg.payload.sound_bruto === undefined && msg.topic !== \"update_inputs\") return null;\n    \n    if (msg.payload.sound_bruto !== undefined) {\n        state.light = Math.round(msg.payload.luz_percent || 0);\n        \n        // CONVERSIÓN DE RUIDO A PORCENTAJE (Escala 0-4095 mapeada a 0-100%)\n        var raw_sound = msg.payload.sound_bruto || 0;\n        state.sound = Math.round(Math.min((raw_sound / 4095) * 100, 100));\n        \n        state.presence = msg.payload.presencia || false;\n    }\n}\n\n// --- 4. LÓGICA DOMÓTICA (REGLAS DE NEGOCIO) ---\n\n// Temporizador de inactividad (Para apagar luces si el aula queda vacía)\nif (!state.presence) {\n    state.timer_idle += 1;\n} else {\n    state.timer_idle = 0;  \n}\n\n// A. Actuador: ILUMINACIÓN ARTIFICIAL\n// REGLA 1: Se enciende SOLO si hay presencia Y la luz natural es 30% o menos.\nif (state.presence && state.light <= 30) {\n    state.light_status = true;\n} else {\n    // REGLA 2: Se apaga si el aula lleva inactiva mucho tiempo O si el Sol da luz mayor al 30%.\n    if (state.timer_idle > 30 || state.light > 30) {\n        state.light_status = false;\n    }\n}\n\n// B. Actuador: VENTILACIÓN / AFORO\n// REGLA 3: El ventilador se enciende estrictamente si el nivel de ruido supera el 30%.\nvar previous_ac_status = state.ac_status;\n\nif (state.sound > 30) {\n    state.ac_status = true;\n} else {\n    state.ac_status = false;\n}\n\n// Guardamos el nuevo estado calculado en memoria\ncontext.set('state', state);\n\n// --- 5. ENRUTAMIENTO DE SALIDAS (UI y HARDWARE) ---\n// Empaquetado de datos para dibujar el Dashboard web\nvar ui_msg = {\n    payload: {\n        inputs: {\n            light: state.light,\n            sound: state.sound,\n            presence: state.presence,\n            timer: state.timer_idle\n        },\n        actuators: {\n            light: state.light_status,\n            ac: state.ac_status\n        },\n        config: {\n            sim: sim_active\n        }\n    }\n};\n\n// Construcción del comando MQTT solo si el ventilador cambió de estado (Optimiza red)\nvar mqtt_cmd_msg = null;\nif (state.ac_status !== previous_ac_status && !sim_active) {\n    mqtt_cmd_msg = {\n        payload: state.ac_status ? \"FAN_ON\" : \"FAN_OFF\"\n    };\n}\n\n// Retorno múltiple: \n// Array índice 0 -> Se envía a la interfaz gráfica\n// Array índice 1 -> Se envía vía MQTT al ESP32\nreturn [ui_msg, mqtt_cmd_msg];",
        "outputs": 2,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 620,
        "y": 720,
        "wires": [
            [
                "5a2d4607792c2722"
            ],
