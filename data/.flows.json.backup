    {
        "id": "ui_botones_globales",
        "type": "ui_template",
        "z": "d8dc90e837e21ab6",
        "group": "group_esc1_v2",
        "name": "Inyectar Botones Globales (Sidebar)",
        "order": 10,
        "width": "0",
        "height": "0",
        "format": "<script>\n(function(scope) {\n    function addGlobalButtons() {\n        var menu = document.querySelector('md-list');\n        if(!menu) {\n            setTimeout(addGlobalButtons, 500);\n            return;\n        }\n        if(document.getElementById('btn-iniciar-global')) return;\n\n        var divider = document.createElement('md-divider');\n        menu.appendChild(divider);\n\n        // 1. Botón Iniciar Rendimiento\n        var liIniciar = document.createElement('md-list-item');\n        liIniciar.id = 'btn-iniciar-global';\n        liIniciar.className = \"md-no-style\";\n        liIniciar.innerHTML = '<md-button style=\"margin-left: 1cm; color:#27ae60; font-weight:bold; width:100%; text-align:left; text-transform:none;\">Iniciar Rendimiento</md-button>';\n        liIniciar.onclick = function() {\n            var hash = window.location.hash.split('?')[0];\n            var tabMap = {\n                \"#!/0\": \"Inicio\",\n                \"#!/1\": \"1. Recolección de datos\",\n                \"#!/2\": \"2. Limpieza Datos\",\n                \"#!/3\": \"3. Predicción IA\",\n                \"#!/4\": \"4. Aula Inteligente\",\n                \"#!/5\": \"5. Nube (Proyector)\",\n                \"#!/6\": \"6. Participar (Celular)\",\n                \"#!/7\": \"7. Encuesta\"\n            };\n            var currentTab = tabMap[hash] || \"Escenario Desconocido (\" + hash + \")\";\n\n            if(confirm(\"¿Iniciar la recolección automática de métricas (cada 5 seg) para este escenario?\")) {\n                 scope.send({topic: \"iniciar\", payload: currentTab});\n                 alert(\" Recolección INICIADA para:\\n\" + currentTab);\n            }\n        };\n        menu.appendChild(liIniciar);\n\n        // 2. Botón Terminar Rendimiento\n        var liTerminar = document.createElement('md-list-item');\n        liTerminar.id = 'btn-terminar-global';\n        liTerminar.className = \"md-no-style\";\n        liTerminar.innerHTML = '<md-button style=\"margin-left: 1cm; color:#f39c12; font-weight:bold; width:100%; text-align:left; text-transform:none;\">Terminar Rendimiento</md-button>';\n        liTerminar.onclick = function() {\n             scope.send({topic: \"terminar\", payload: \"\"});\n             alert(\" Recolección de métricas DETENIDA.\");\n        };\n        menu.appendChild(liTerminar);\n\n        // 3. Botón Limpiar Historial\n        var liLimpiar = document.createElement('md-list-item');\n        liLimpiar.id = 'btn-limpiar-global';\n        liLimpiar.className = \"md-no-style\";\n        liLimpiar.innerHTML = '<md-button style=\"margin-left: 1cm; color:#c0392b; font-weight:bold; width:100%; text-align:left; text-transform:none;\"> Limpiar Historial</md-button>';\n        liLimpiar.onclick = function() {\n            if(confirm(\"⚠️ ATENCIÓN: ¿Seguro que desea eliminar permanentemente todas las métricas de rendimiento guardadas?\")) {\n                 scope.send({topic: \"limpiar\", payload: \"borrar\"});\n                 alert(\" Historial de métricas borrado exitosamente.\");\n            }\n        };\n        menu.appendChild(liLimpiar);\n    }\n    addGlobalButtons();\n})(scope);\n</script>",
