    {
        "id": "node_function_format",
        "type": "function",
        "z": "dc7152bb2106ef80",
        "name": "Estructurar a JSON Plano",
        "func": "var d = new Date();\nvar fechaStr = d.toISOString().split('T')[0] + \" \" + d.toTimeString().split(' ')[0];\n\nvar p = msg.payload;\n\nmsg.payload = {\n    \"Fecha_Hora\": fechaStr,\n    \"Nivel_Instruccion\": p.q1,\n    \"Claridad_Exposicion\": parseInt(p.q2),\n    \"Facilidad_Conexion\": parseInt(p.q3),\n    \"Interfaz_Visual\": parseInt(p.q4),\n    \"Precision_Sensores\": parseInt(p.q5),\n    \"Reaccion_Actuadores\": parseInt(p.q6),\n    \"Escenario_Favorito\": p.q7,\n    \"Impacto_Vocacional\": p.q8,\n    \"Nivel_Innovacion\": parseInt(p.q9),\n    \"Sugerencias_Comentarios\": p.q10\n};\n\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
