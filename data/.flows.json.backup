    {
        "id": "5e711952922318f8",
        "type": "function",
        "z": "0b3362ab9d38a37d",
        "name": "LÓGICA SENSOR V2 (Hybrid)",
        "func": "// --- 1. GESTIÓN DE ESTADO ---\nvar sim_active = context.get('sim_active');\nif (sim_active === undefined) sim_active = true;\n\nvar t = context.get('t') || 0;\n\n// --- 2. ENTRADAS DE CONTROL ---\nif (msg.topic === \"sim_switch\") {\n    sim_active = msg.payload;\n    context.set('sim_active', sim_active);\n    return { payload: { config: { sim: sim_active } } };\n}\n\n// --- 3. PROCESAMIENTO DE DATOS ---\nvar d = { sound: 0, light: 0, dist: 0, pres: false, sound_peak: 2000 };\n\nif (sim_active) {\n    if (msg.payload && msg.payload.sound_bruto !== undefined) return null;\n    t += 0.2;\n    context.set('t', t);\n\n    var noise = (Math.random() * 200) - 100;\n    d.sound = Math.floor(2000 + 500 * Math.sin(t * 0.5) + noise);\n    d.dist = 20 + 100 * Math.abs(Math.sin(t * 0.1));\n    d.light = 50 + 30 * Math.cos(t * 0.2);\n\n    if (Math.random() > 0.9) context.set('last_pres', !context.get('last_pres'));\n    d.pres = context.get('last_pres') || false;\n    d.sound_peak = d.sound; \n\n} else {\n    if (!msg.payload || msg.payload.sound_bruto === undefined) return null;\n    d.sound = msg.payload.sound_bruto || 0;\n    d.dist = msg.payload.distancia || 0;\n    d.light = msg.payload.luz_percent || 0;\n    d.pres = msg.payload.presencia || false;\n    d.sound_peak = msg.payload.sound_raw_peak || 2000; \n}\n\n// --- FORZAR NÚMEROS ENTEROS ---\nd.dist = Math.round(d.dist);\nd.light = Math.round(d.light);\n\n// ========================================================\n// DETECCIÓN DE ERRORES / DESCONEXIÓN (TODOS LOS SENSORES)\n// ========================================================\nvar mic_flatline_count = context.get('mic_flatline_count') || 0;\nvar last_mic_val = context.get('last_mic_val') || 0;\n\nif (!sim_active) {\n    if ((d.sound_peak >= 4090 || d.sound_peak <= 10) && (d.sound_peak === last_mic_val)) {\n        mic_flatline_count++;\n    } else {\n        mic_flatline_count = 0;\n    }\n} else {\n    mic_flatline_count = 0;\n}\n\ncontext.set('mic_flatline_count', mic_flatline_count);\ncontext.set('last_mic_val', d.sound_peak);\n\nvar mic_error = (mic_flatline_count >= 12);\n\n// NUEVO: Detección Radar, LDR y PIR\nvar dist_error = (!sim_active && d.dist <= 0);\nvar ldr_error = (!sim_active && d.light <= 0);\nvar pir_error = (!sim_active && (msg.payload.presencia === undefined || msg.payload.presencia === null || msg.payload.pir_error === true));\n// ========================================================\n\n\n// --- 4. LÓGICA DE NEGOCIO --- \nvar sound_pct = Math.min((d.sound / 4095) * 100, 100);\nvar sound_alert = d.sound > 2400 && !mic_error;\n\nif (mic_error) {\n    sound_pct = 0;\n    sound_alert = false;\n}\n\nvar pres_style = d.pres ?\n    { class: 'bg-danger', icon: 'fa-exclamation-triangle', color: '#d63031', text: '¡INTRUSO!' } :\n    { class: 'bg-safe', icon: 'fa-shield-alt', color: '#00b894', text: 'AREA SEGURA' };\n\nvar dist_num = parseFloat(d.dist);\nvar radar_pct = Math.min((dist_num / 200) * 100, 100);\n\nvar zona = { border: '#00b894', icon: 'fa-check-circle', color: '#00b894', text: 'DESPEJADO', tamper: false };\nif (dist_error) {\n    zona = { border: '#d63031', icon: 'fa-unlink', color: '#d63031', text: 'ERROR', tamper: false };\n    radar_pct = 0;\n} else if (dist_num === 0 && !sim_active) {\n    zona = { border: '#95a5a6', icon: 'fa-unlink', color: '#95a5a6', text: 'SIN ACCIÓN', tamper: false };\n} else if (dist_num < 10) {\n    zona = { border: '#d63031', icon: 'fa-hand-paper', color: '#d63031', text: 'SABOTAJE', tamper: true };\n} else if (dist_num < 25) {\n    zona = { border: '#fbc531', icon: 'fa-exclamation-circle', color: '#fbc531', text: 'PRECAUCIÓN', tamper: false };\n}\n\nvar sun = {};\nvar energy = {};\nif (ldr_error) {\n    sun = { color: '#d63031', shadow: 'none', low_light: false };\n    energy = { text: 'ERROR LECTURA', color: '#d63031' };\n} else if (d.light > 30) {\n    sun = { color: '#95a5a6', shadow: 'none', low_light: false };\n    energy = { text: 'Luz Natural', color: '#00b894' };\n} else {\n    sun = { color: '#f1c40f', shadow: '0 0 20px #f1c40f', low_light: true };\n    energy = { text: 'Luz Artificial', color: '#e1b12c' };\n}\n\n// IA Integrada de Python\nvar ai_count = flow.get('cv_personas') || 0;\nvar ai_status = flow.get('cv_lentes') || \"PERSONAS\";\n\nif (sim_active) {\n    ai_count = d.pres ? (Math.floor(Math.random() * 4) + 1) : 0;\n    ai_status = d.pres ? \"SIMULACIÓN ACTIVA\" : \"SIN ACTIVIDAD\";\n}\n\nmsg.payload = {\n    raw: d,\n    ui: {\n        audio: { pct: sound_pct, alert: sound_alert, error: mic_error },\n        env: { \n            pres: pres_style, \n            radar: radar_pct, \n            zona: zona, \n            sun: sun, \n            energy: energy, \n            ldr_error: ldr_error, \n            dist_error: dist_error, \n            pir_error: pir_error \n        },\n        security: { ai_count: ai_count, ai_status: ai_status }\n    },\n    config: {\n        sim: sim_active\n    }\n};\nreturn msg;",
        "outputs": 1,
        "timeout": "",
        "noerr": 0,
        "initialize": "",
        "finalize": "",
        "libs": [],
        "x": 630,
        "y": 180,
        "wires": [
